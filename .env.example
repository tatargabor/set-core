# set-core environment configuration
# Copy this file to .env and fill in the values below.

# --- Web Dashboard ---
# WT_WEB_PORT=7400
# WT_TAILSCALE_HOSTNAME=your-machine-name.tailnet-xxxx.ts.net

# --- Email notifications (optional) ---
# Set notification: email or notification: desktop+email in orchestration config to enable.
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=noreply@yourdomain.com
# RESEND_TO=you@yourdomain.com
