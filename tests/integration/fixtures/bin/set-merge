#!/bin/bash
# Stub set-merge for integration tests.
# Does a plain git merge without LLM conflict resolution.
# Usage: set-merge <change-name> [--no-push] [--llm-resolve]
change_name="$1"
branch="change/${change_name}"

# Ignore flags (--no-push, --llm-resolve)
shift
while [[ "$1" == --* ]]; do shift; done

# Attempt merge
git merge "$branch" --no-edit 2>/dev/null
exit $?
