#!/bin/bash
# set-orch-core — CLI bridge between bash orchestration scripts and Python core.
#
# Resolves the correct Python (>=3.10 on macOS, python3 on Linux) then
# exec's the real Python entry point. This avoids #!/usr/bin/env python3
# picking up macOS system Python 3.9 which lacks required packages.

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
export SET_TOOLS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source find_python from set-common.sh
source "$SCRIPT_DIR/set-common.sh" 2>/dev/null

PYTHON="$(find_python 2>/dev/null)" || PYTHON="python3"

exec "$PYTHON" "$SET_TOOLS_ROOT/lib/set_orch/cli_entry.py" "$@"
