#!/usr/bin/env bash
# wt-merge - Merge a worktree branch to target branch

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/wt-common.sh"

usage() {
    cat <<EOF
Usage: wt-merge <change-id> [options]

Merge a worktree's branch into a target branch.

Arguments:
  change-id               The change identifier

Options:
  -p, --project <name>    Use specific project (default: auto-detect)
  --to <branch>           Target branch (default: auto-detect main/master)
  --squash                Squash commits into one
  --no-delete             Keep source branch after merge
  --no-push               Don't push after merge (default: push)
  --llm-resolve           Use LLM to resolve merge conflicts automatically
  --no-conservation-check Skip post-LLM conservation check (emergency bypass)
  -h, --help              Show this help

Examples:
  wt-merge add-user-auth
  wt-merge add-user-auth --to develop
  wt-merge add-user-auth --squash
EOF
}

# Find the default branch (main or master)
find_default_branch() {
    local project_path="$1"

    if git -C "$project_path" show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main"
    elif git -C "$project_path" show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master"
    else
        echo ""
    fi
}

# Patterns for generated/build files that can be safely auto-resolved on merge conflict.
# These files are regenerated by the build system, so accepting "ours" (target branch) is safe.
GENERATED_FILE_PATTERNS=(
    "tsconfig.tsbuildinfo"
    "*.tsbuildinfo"
    "next-env.d.ts"
    "package-lock.json"
    "yarn.lock"
    "pnpm-lock.yaml"
    ".next/**"
    "dist/**"
    "build/**"
    "coverage/**"
    "node_modules/**"
    ".claude/**"
    ".wt-tools/**"
)

# Read profile-specific generated file patterns if available
_PROFILE_PATTERNS_FILE="${PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}/wt/plugins/.generated-file-patterns"
if [[ -f "$_PROFILE_PATTERNS_FILE" ]]; then
    while IFS= read -r pat; do
        [[ -n "$pat" ]] && GENERATED_FILE_PATTERNS+=("$pat")
    done < "$_PROFILE_PATTERNS_FILE"
fi

# Hardcoded JS lockfile-to-PM map (fallback when no profile is loaded).
declare -A _FALLBACK_LOCKFILE_PM_MAP=(
    ["pnpm-lock.yaml"]="pnpm"
    ["yarn.lock"]="yarn"
    ["package-lock.json"]="npm"
)

# Read profile lockfile-PM map if available (written by wt-project init).
_LOCKFILE_PM_MAP_FILE="${PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}/wt/plugins/.lockfile-pm-map"
declare -A _PROFILE_LOCKFILE_PM_MAP=()
if [[ -f "$_LOCKFILE_PM_MAP_FILE" ]]; then
    while IFS='=' read -r lockfile pm; do
        [[ -n "$lockfile" && -n "$pm" ]] && _PROFILE_LOCKFILE_PM_MAP["$lockfile"]="$pm"
    done < "$_LOCKFILE_PM_MAP_FILE"
fi

# Check if a file is a lock file (using profile map then hardcoded fallback).
# Returns 0 if lock file, 1 otherwise. Sets LOCKFILE_PM to the package manager.
is_lockfile() {
    local file="$1"
    local basename
    basename=$(basename "$file")

    # Profile map first
    if [[ ${#_PROFILE_LOCKFILE_PM_MAP[@]} -gt 0 && -n "${_PROFILE_LOCKFILE_PM_MAP[$basename]+x}" ]]; then
        LOCKFILE_PM="${_PROFILE_LOCKFILE_PM_MAP[$basename]}"
        return 0
    fi

    # Hardcoded JS fallback
    if [[ -n "${_FALLBACK_LOCKFILE_PM_MAP[$basename]+x}" ]]; then
        LOCKFILE_PM="${_FALLBACK_LOCKFILE_PM_MAP[$basename]}"
        return 0
    fi

    LOCKFILE_PM=""
    return 1
}

# Regenerate a lock file by running the appropriate PM install command.
# Stages the regenerated file. Returns 0 on success, 1 on failure.
regenerate_lockfile() {
    local lockfile="$1"
    local pm="$2"

    if [[ -z "$pm" ]]; then
        warn "Cannot regenerate $lockfile — unknown package manager"
        return 1
    fi

    local install_cmd="$pm install"
    # pnpm needs --no-frozen-lockfile to allow lock file changes
    if [[ "$pm" == "pnpm" ]]; then
        install_cmd="pnpm install --no-frozen-lockfile"
    fi

    info "Regenerating $lockfile via: $install_cmd"
    if eval "$install_cmd" 2>/dev/null; then
        git add "$lockfile" 2>/dev/null
        info "Lock file regenerated and staged: $lockfile"
        return 0
    else
        warn "Lock file regeneration failed for $lockfile (continuing with 'ours' version)"
        return 1
    fi
}

# Runtime file patterns that should never be tracked in git.
RUNTIME_FILE_PATTERNS=(
    ".wt-tools/.last-memory-commit"
    ".wt-tools/agents/"
    ".wt-tools/orphan-detect/"
    "orchestration-state.json"
    "orchestration-state.json.lock"
    "orchestration-state-events.jsonl"
    "orchestration-events.jsonl"
    "orchestration-plan.json"
    "orchestration.log"
)

# Remove runtime files from git index and ensure they are in .gitignore.
# Returns 0 if any files were cleaned, 1 if nothing to do.
cleanup_runtime_files() {
    local project_path="$1"
    local cleaned=false

    # Remove tracked runtime files from index
    for pattern in "${RUNTIME_FILE_PATTERNS[@]}"; do
        local full_path="$project_path/$pattern"
        if [[ "$pattern" == */ ]]; then
            # Directory pattern — check if any tracked files match
            local tracked
            tracked=$(git -C "$project_path" ls-files "$pattern" 2>/dev/null)
            if [[ -n "$tracked" ]]; then
                git -C "$project_path" rm -r --cached "${pattern%/}" 2>/dev/null || true
                cleaned=true
            fi
        else
            # File pattern
            if git -C "$project_path" ls-files --error-unmatch "$pattern" &>/dev/null; then
                git -C "$project_path" rm --cached "$pattern" 2>/dev/null || true
                cleaned=true
            fi
        fi
    done

    # Ensure patterns are in .gitignore
    local gitignore="$project_path/.gitignore"
    local patterns_to_add=()
    for pattern in "${RUNTIME_FILE_PATTERNS[@]}"; do
        if [[ ! -f "$gitignore" ]] || ! grep -qF "$pattern" "$gitignore" 2>/dev/null; then
            patterns_to_add+=("$pattern")
        fi
    done

    if [[ ${#patterns_to_add[@]} -gt 0 ]]; then
        # Add a section header if .gitignore doesn't have one for wt-tools
        if [[ ! -f "$gitignore" ]] || ! grep -q "wt-tools runtime" "$gitignore" 2>/dev/null; then
            echo "" >> "$gitignore"
            echo "# wt-tools runtime files" >> "$gitignore"
        fi
        for pattern in "${patterns_to_add[@]}"; do
            echo "$pattern" >> "$gitignore"
        done
        git -C "$project_path" add .gitignore 2>/dev/null || true
        cleaned=true
    fi

    if $cleaned; then
        return 0
    fi
    return 1
}

# Check if a file matches any generated file pattern.
is_generated_file() {
    local file="$1"
    local basename
    basename=$(basename "$file")
    for pattern in "${GENERATED_FILE_PATTERNS[@]}"; do
        case "$pattern" in
            *"/**")
                # Directory prefix match
                local dir_prefix="${pattern%/**}"
                if [[ "$file" == "$dir_prefix/"* ]]; then
                    return 0
                fi
                ;;
            *"*"*)
                # Glob match on basename
                # shellcheck disable=SC2254
                if [[ "$basename" == ${pattern} ]]; then
                    return 0
                fi
                ;;
            *)
                # Exact match: try full path first, then basename
                if [[ "$file" == "$pattern" || "$basename" == "$pattern" ]]; then
                    return 0
                fi
                ;;
        esac
    done
    return 1
}

# Try to auto-resolve merge conflicts in generated/build files.
# Accepts "ours" (target branch) for generated files — they'll be regenerated by build.
# When partial=true, resolves generated files even if non-generated conflicts remain.
# Returns 0 if all conflicts resolved, 1 if non-generated files still have conflicts.
auto_resolve_generated_files() {
    local conflicted_files="$1"
    local partial="${2:-false}"
    local generated_files=()
    local has_non_generated=false

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        if is_generated_file "$file"; then
            generated_files+=("$file")
        else
            has_non_generated=true
        fi
    done <<< "$conflicted_files"

    # No generated files to resolve
    if [[ ${#generated_files[@]} -eq 0 ]]; then
        return 1
    fi

    # Without partial mode, only resolve if ALL files are generated (original behavior)
    if ! $partial && $has_non_generated; then
        return 1
    fi

    # Resolve generated files with "ours", then regenerate lock files
    for file in "${generated_files[@]}"; do
        git checkout --ours "$file" 2>/dev/null && git add "$file" 2>/dev/null

        # If this is a lock file, regenerate it and emit machine-readable marker
        if is_lockfile "$file"; then
            echo "LOCKFILE_CONFLICTED=$file"
            regenerate_lockfile "$file" "$LOCKFILE_PM" || true
        fi
    done

    info "Auto-resolved generated file conflicts: ${generated_files[*]}"

    # Return success only if no non-generated conflicts remain
    if $has_non_generated; then
        return 1
    fi
    return 0
}

# Programmatic package.json merge — resolves additive dependency conflicts
# that LLM resolvers consistently fail on. Uses jq to merge all object fields,
# keeping entries from both sides.
# Returns 0 if package.json conflict resolved, 1 if not applicable or failed.
auto_resolve_package_json() {
    local conflicted_files="$1"
    local source_branch="$2"
    local target_branch="$3"

    # Check if package.json is among conflicted files
    local has_pkg=false
    while IFS= read -r file; do
        [[ "$file" == "package.json" ]] && has_pkg=true
    done <<< "$conflicted_files"
    $has_pkg || return 1

    # Get both versions
    local ours_json theirs_json
    ours_json=$(git show ":2:package.json" 2>/dev/null) || return 1
    theirs_json=$(git show ":3:package.json" 2>/dev/null) || return 1

    # Validate both are valid JSON
    echo "$ours_json" | jq empty 2>/dev/null || return 1
    echo "$theirs_json" | jq empty 2>/dev/null || return 1

    # Deep merge: theirs (source/feature) wins on scalar conflicts,
    # but objects are recursively merged (keeps deps from both sides)
    local merged
    merged=$(jq -s '
        def deep_merge:
            if length == 2 then
                .[0] as $a | .[1] as $b |
                if ($a | type) == "object" and ($b | type) == "object" then
                    ($a | keys) + ($b | keys) | unique | map(
                        . as $k |
                        if ($a | has($k)) and ($b | has($k)) then
                            {($k): ([$a[$k], $b[$k]] | deep_merge)}
                        elif ($b | has($k)) then
                            {($k): $b[$k]}
                        else
                            {($k): $a[$k]}
                        end
                    ) | add // {}
                else
                    .[1]  # scalar conflict: prefer theirs (feature branch)
                end
            else .[0]
            end;
        deep_merge
    ' <(echo "$ours_json") <(echo "$theirs_json") 2>/dev/null) || return 1

    # Validate merged result
    echo "$merged" | jq empty 2>/dev/null || return 1

    # Write merged package.json and stage it
    echo "$merged" > package.json
    git add package.json
    info "Auto-resolved package.json conflict (programmatic deep merge)"
    return 0
}

# Programmatic JSON file merge — resolves additive conflicts in translation
# and config JSON files. Uses the same jq deep-merge as package.json.
# Skips package.json (handled by auto_resolve_package_json above).
# Returns 0 if at least one JSON file was resolved, 1 if none applicable.
auto_resolve_json_files() {
    local conflicted_files="$1"
    local source_branch="$2"
    local target_branch="$3"

    local resolved_count=0
    while IFS= read -r file; do
        # Only .json files, skip package.json (already handled)
        [[ "$file" == *.json ]] || continue
        [[ "$file" == "package.json" ]] && continue

        # Get both versions
        local ours_json theirs_json
        ours_json=$(git show ":2:$file" 2>/dev/null) || continue
        theirs_json=$(git show ":3:$file" 2>/dev/null) || continue

        # Validate both are valid JSON
        echo "$ours_json" | jq empty 2>/dev/null || continue
        echo "$theirs_json" | jq empty 2>/dev/null || continue

        # Deep merge: same strategy as package.json
        local merged
        merged=$(jq -s '
            def deep_merge:
                if length == 2 then
                    .[0] as $a | .[1] as $b |
                    if ($a | type) == "object" and ($b | type) == "object" then
                        ($a | keys) + ($b | keys) | unique | map(
                            . as $k |
                            if ($a | has($k)) and ($b | has($k)) then
                                {($k): ([$a[$k], $b[$k]] | deep_merge)}
                            elif ($b | has($k)) then
                                {($k): $b[$k]}
                            else
                                {($k): $a[$k]}
                            end
                        ) | add // {}
                    else
                        .[1]  # scalar conflict: prefer theirs (feature branch)
                    end
                else .[0]
                end;
            deep_merge
        ' <(echo "$ours_json") <(echo "$theirs_json") 2>/dev/null) || continue

        # Validate merged result
        echo "$merged" | jq empty 2>/dev/null || continue

        # Write merged file and stage it
        echo "$merged" > "$file"
        git add "$file"
        info "Auto-resolved $file conflict (programmatic deep merge)"
        resolved_count=$((resolved_count + 1))
    done <<< "$conflicted_files"

    [[ $resolved_count -gt 0 ]] && return 0 || return 1
}

# Resolve delete/modify and rename conflicts without LLM
# DU = HEAD deleted, feature modified → keep feature (git checkout --theirs)
# UD = feature deleted, HEAD modified → accept deletion (git rm)
# Verified with actual git status --porcelain output.
auto_resolve_structural_conflicts() {
    local conflicted_files="$1"
    local resolved=0

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        local status
        status=$(git status --porcelain "$file" 2>/dev/null | head -1)
        [[ -z "$status" ]] && continue  # special conflict state, skip

        case "$status" in
            DU*)
                # HEAD (main) deleted, feature modified → keep feature's version
                git checkout --theirs "$file" 2>/dev/null && git add "$file" 2>/dev/null
                resolved=$((resolved + 1))
                info "Auto-resolved DU (keep feature): $file"
                ;;
            UD*)
                # Feature deleted, HEAD (main) modified → accept feature's deletion
                git rm "$file" 2>/dev/null || true
                resolved=$((resolved + 1))
                info "Auto-resolved UD (accept deletion): $file"
                ;;
            *)
                # Runtime/tmp files — accept either side
                if [[ "$file" == tmp/* || "$file" == .claude/logs/* || "$file" == .claude/ralph-terminal.pid || "$file" == .wt/* ]]; then
                    git checkout --theirs "$file" 2>/dev/null && git add "$file" 2>/dev/null
                    resolved=$((resolved + 1))
                    info "Auto-resolved runtime file: $file"
                fi
                ;;
        esac
    done <<< "$conflicted_files"

    [[ $resolved -gt 0 ]] && return 0 || return 1
}

llm_resolve_conflicts() {
    local source_branch="$1"
    local target_branch="$2"
    local conflicted_files="$3"

    info "Attempting LLM conflict resolution..."

    # Extract only conflict hunks with context (not entire files)
    # This dramatically reduces prompt size for large files
    # Context-aware merge: gather scope + branch history
    local scope="${WT_MERGE_SCOPE:-}"
    local source_log target_log context_section=""
    source_log=$(git log --oneline "$target_branch..$source_branch" 2>/dev/null | head -10)
    target_log=$(git log --oneline "$source_branch..$target_branch" 2>/dev/null | head -10)

    if [[ -n "$scope" ]]; then
        context_section="
CONTEXT — What the source branch implemented:
$scope

Source branch commits:
$source_log

Target branch recent commits:
$target_log

RESOLUTION STRATEGY:
- The source branch is a FEATURE being merged into main
- Prefer source branch changes for feature-specific code (new files, new functions)
- Keep BOTH sides for additive changes (imports, config entries, deps)
- For config files: use target (main) as base, add source's new entries
- For test files: prefer source (they contain the feature's tests)

"
    fi

    local prompt="You are resolving git merge conflicts.
Source branch: $source_branch (being merged INTO target)
Target branch: $target_branch
${context_section}
Below are the CONFLICT HUNKS extracted from each file (with 3 lines of surrounding context).
Resolve each conflict by keeping both sides' changes where possible (integrate, don't pick one side).
If changes are contradictory, prefer the source branch (the feature being merged).

IMPORTANT — Additive conflict pattern:
When both sides ADD new entries to the same list, array, object literal, import block,
enum, or similar collection — KEEP ALL entries from BOTH sides. Do NOT pick one side.

Example:
<<<<<<< HEAD
  \"action_a\",
  \"action_b\",
=======
  \"action_x\",
  \"action_y\",
>>>>>>> feature

Correct resolution (keep all):
  \"action_a\",
  \"action_b\",
  \"action_x\",
  \"action_y\",

Output ONLY the resolved files. For each file, output a header line exactly like:
--- FILE: <path> ---
followed by the COMPLETE file content (no conflict markers, no truncation).
Do not output anything else — no explanations, no markdown fences.

Conflicted files:
"
    local total_lines=0
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue

        # Inject strategy hint if available (input prompt only)
        local file_hint
        file_hint=$(get_llm_hint "$file" 2>/dev/null || true)
        if [[ -n "$file_hint" ]]; then
            prompt+="
[STRATEGY CONTEXT for $file]
$file_hint
[END STRATEGY CONTEXT]
"
        fi

        # Extract conflict hunks with 3 lines of context before/after
        local hunks
        hunks=$(awk '
            BEGIN { ctx=3 }
            /^<{7}/ { for(i=ctx;i>=1;i--) if(before[i]!="") print before[i]; collecting=1 }
            collecting { print; if(/^>{7}/) { collecting=0; after=ctx; next } }
            !collecting && after>0 { print; after-- }
            !collecting { for(i=ctx;i>=2;i--) before[i]=before[i-1]; before[1]=$0 }
        ' "$file")
        local hunk_lines
        hunk_lines=$(echo "$hunks" | wc -l)
        local file_lines
        file_lines=$(wc -l < "$file")
        total_lines=$((total_lines + hunk_lines))
        if [[ $hunk_lines -lt $((file_lines / 2)) ]]; then
            # Hunks are significantly smaller than full file — use hunks
            prompt+="
--- FILE: $file (conflict hunks only, full file is ${file_lines} lines) ---
$hunks"
        else
            # Hunks are most of the file anyway — send full file
            prompt+="
--- FILE: $file ---
$(cat "$file")
"
            total_lines=$((total_lines - hunk_lines + file_lines))
        fi
    done <<< "$conflicted_files"

    local prompt_len=${#prompt}
    if [[ $prompt_len -gt 100000 ]]; then
        warn "LLM merge prompt is large (${prompt_len} chars) — may be slow"
    fi

    # Call Claude — model selection based on conflict size
    local llm_output rc=0
    if [[ $total_lines -gt 200 ]]; then
        # Large conflict: skip sonnet (always times out), go directly to opus
        info "Using opus directly ($total_lines conflict lines > 200 threshold)"
        llm_output=$(export RUN_CLAUDE_TIMEOUT=600; echo "$prompt" | run_claude --model "$(resolve_model_id opus)" --max-turns 1) || rc=$?
    else
        # Small conflict: try sonnet first (cheaper), escalate to opus on failure
        info "Trying sonnet first ($total_lines conflict lines)"
        llm_output=$(export RUN_CLAUDE_TIMEOUT=300; echo "$prompt" | run_claude --model "$(resolve_model_id sonnet)" --max-turns 1) || rc=$?
        if [[ $rc -ne 0 || -z "$llm_output" ]]; then
            warn "LLM conflict resolution failed with sonnet (exit code: $rc), escalating to opus"
            rc=0
            llm_output=$(export RUN_CLAUDE_TIMEOUT=600; echo "$prompt" | run_claude --model "$(resolve_model_id opus)" --max-turns 1) || rc=$?
        fi
    fi

    if [[ $rc -ne 0 || -z "$llm_output" ]]; then
        warn "LLM conflict resolution failed with opus (exit code: $rc)"
        return 1
    fi

    # Parse output: extract each file block (full file content from LLM)
    local current_file="" current_content="" files_resolved=0
    while IFS= read -r line; do
        if [[ "$line" =~ ^---\ FILE:\ (.+)\ ---$ ]]; then
            # Write previous file if any
            if [[ -n "$current_file" ]]; then
                printf '%s\n' "$current_content" > "$current_file"
                git add "$current_file"
                files_resolved=$((files_resolved + 1))
            fi
            current_file="${BASH_REMATCH[1]}"
            # Strip trailing whitespace and parenthetical notes from filename
            current_file=$(echo "$current_file" | sed 's/ *(.*//')
            current_content=""
        elif [[ -n "$current_file" ]]; then
            if [[ -z "$current_content" ]]; then
                current_content="$line"
            else
                current_content+=$'\n'"$line"
            fi
        fi
    done <<< "$llm_output"

    # Write last file
    if [[ -n "$current_file" ]]; then
        printf '%s\n' "$current_content" > "$current_file"
        git add "$current_file"
        files_resolved=$((files_resolved + 1))
    fi

    if [[ $files_resolved -eq 0 ]]; then
        warn "LLM output did not contain any resolved files"
        return 1
    fi

    # Check if any conflicts remain
    local remaining_conflicts
    remaining_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
    if [[ -n "$remaining_conflicts" ]]; then
        warn "LLM resolved $files_resolved files but conflicts remain in: $remaining_conflicts"
        return 1
    fi

    info "LLM resolved $files_resolved conflicted file(s)"

    # Record resolved files for conservation check
    LLM_RESOLVED_FILES=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^---\ FILE:\ (.+)\ ---$ ]]; then
            local fname="${BASH_REMATCH[1]}"
            fname=$(echo "$fname" | sed 's/ *(.*//')
            LLM_RESOLVED_FILES+=("$fname")
        fi
    done <<< "$llm_output"

    return 0
}

# ─── Conservation Check ──────────────────────────────────────────
# Verifies that additions from both sides of a merge are preserved
# in the LLM-resolved output. Runs BEFORE git commit.

# Global: populated by llm_resolve_conflicts()
LLM_RESOLVED_FILES=()

# Compute lines added by a branch relative to merge-base.
# Returns trimmed, non-blank, unique lines present in branch but not in base.
# Args: base_ref, branch_ref, file_path
# Output: one line per addition on stdout
compute_additions() {
    local base_ref="$1"
    local branch_ref="$2"
    local file_path="$3"

    local base_content branch_content
    base_content=$(git show "${base_ref}:${file_path}" 2>/dev/null || echo "")
    branch_content=$(git show "${branch_ref}:${file_path}" 2>/dev/null || echo "")

    # Trimmed (leading, trailing, and internal multi-space → single space), non-blank, sorted unique lines
    comm -13 \
        <(echo "$base_content" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/[[:space:]]\+/ /g' | grep -v '^$' | sort -u) \
        <(echo "$branch_content" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/[[:space:]]\+/ /g' | grep -v '^$' | sort -u)
}

# Check if a file is binary (git reports - for additions/deletions).
is_binary_file() {
    local file_path="$1"
    local numstat
    numstat=$(git diff --numstat HEAD -- "$file_path" 2>/dev/null | head -1)
    [[ "$numstat" == -* ]]
}

# Run conservation check on a single file.
# Returns 0 if all additions preserved, 1 if data lost.
# Outputs missing lines to stdout.
# Args: merge_base, ours_ref, theirs_ref, file_path
conservation_check() {
    local merge_base="$1"
    local ours_ref="$2"
    local theirs_ref="$3"
    local file_path="$4"

    # Skip binary files
    if is_binary_file "$file_path"; then
        info "Conservation: skipping binary file $file_path"
        return 0
    fi

    # Skip if file doesn't exist in merge-base (delete/modify conflict detection)
    local base_exists=true
    git show "${merge_base}:${file_path}" &>/dev/null || base_exists=false

    local ours_exists=true
    git show "${ours_ref}:${file_path}" &>/dev/null || ours_exists=false

    local theirs_exists=true
    git show "${theirs_ref}:${file_path}" &>/dev/null || theirs_exists=false

    # Delete/modify: one side deletes, other modifies — skip
    if ! $ours_exists || ! $theirs_exists; then
        info "Conservation: skipping $file_path (delete/modify conflict)"
        return 0
    fi

    # File new on one side only — nothing to lose from the non-existent side
    if ! $base_exists && ($ours_exists != $theirs_exists); then
        return 0
    fi

    # Compute additions from each side relative to base
    # (if base doesn't exist, treat as empty — file new on both sides)
    local ours_added theirs_added
    ours_added=$(compute_additions "$merge_base" "$ours_ref" "$file_path")
    theirs_added=$(compute_additions "$merge_base" "$theirs_ref" "$file_path")

    # Get merged file content (on disk, after LLM resolution)
    local merged_lines
    merged_lines=$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/[[:space:]]\+/ /g' "$file_path" | grep -v '^$' | sort -u)

    # Check: are all additions from ours present in merged?
    local missing="" missing_count=0 side=""
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! echo "$merged_lines" | grep -qxF "$line"; then
            missing+="  [ours] $line"$'\n'
            missing_count=$((missing_count + 1))
        fi
    done <<< "$ours_added"

    # Check: are all additions from theirs present in merged?
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! echo "$merged_lines" | grep -qxF "$line"; then
            missing+="  [theirs] $line"$'\n'
            missing_count=$((missing_count + 1))
        fi
    done <<< "$theirs_added"

    if [[ $missing_count -gt 0 ]]; then
        local ours_count theirs_count
        ours_count=$(echo "$ours_added" | grep -c . 2>/dev/null || echo 0)
        theirs_count=$(echo "$theirs_added" | grep -c . 2>/dev/null || echo 0)
        echo "CONSERVATION FAILED: $file_path"
        echo "  Additions — ours: $ours_count lines, theirs: $theirs_count lines"
        echo "  Missing: $missing_count lines"
        echo "$missing" | head -20
        return 1
    fi

    return 0
}

# Run conservation checks on all LLM-resolved files.
# Args: merge_base, ours_ref, theirs_ref
# Returns 0 if all pass, 1 if any fail.
run_conservation_checks() {
    local merge_base="$1"
    local ours_ref="$2"
    local theirs_ref="$3"

    if [[ ${#LLM_RESOLVED_FILES[@]} -eq 0 ]]; then
        return 0
    fi

    info "Running conservation checks on ${#LLM_RESOLVED_FILES[@]} LLM-resolved file(s)..."

    local failed=false
    local report=""
    for file_path in "${LLM_RESOLVED_FILES[@]}"; do
        local result
        result=$(conservation_check "$merge_base" "$ours_ref" "$theirs_ref" "$file_path" 2>&1) || {
            failed=true
            report+="$result"$'\n'
        }
    done

    if $failed; then
        error "MERGE BLOCKED: conservation check failed — additions lost"
        echo "$report"
        return 1
    fi

    info "Conservation checks passed — all additions preserved"
    return 0
}

# ─── Entity Counting (for additive strategy) ─────────────────────

# Count lines matching a regex pattern in a file or git ref.
# Args: source (file path or "git:ref:path"), pattern
count_entities() {
    local source="$1"
    local pattern="$2"

    if [[ "$source" == git:* ]]; then
        local ref_and_path="${source#git:}"
        local ref="${ref_and_path%%:*}"
        local path="${ref_and_path#*:}"
        git show "${ref}:${path}" 2>/dev/null | grep -cE "$pattern" || echo 0
    else
        grep -cE "$pattern" "$source" 2>/dev/null || echo 0
    fi
}

# Run entity count check for a single file with additive strategy.
# Args: merge_base, ours_ref, theirs_ref, file_path, entity_pattern
# Returns 0 if entity count is preserved, 1 if dropped.
entity_count_check() {
    local merge_base="$1"
    local ours_ref="$2"
    local theirs_ref="$3"
    local file_path="$4"
    local entity_pattern="$5"

    local base_count ours_count theirs_count merged_count
    base_count=$(count_entities "git:${merge_base}:${file_path}" "$entity_pattern")
    ours_count=$(count_entities "git:${ours_ref}:${file_path}" "$entity_pattern")
    theirs_count=$(count_entities "git:${theirs_ref}:${file_path}" "$entity_pattern")
    merged_count=$(count_entities "$file_path" "$entity_pattern")

    local ours_added=$((ours_count - base_count))
    local theirs_added=$((theirs_count - base_count))
    # Clamp negatives (deletions) to 0 for expected calculation
    [[ $ours_added -lt 0 ]] && ours_added=0
    [[ $theirs_added -lt 0 ]] && theirs_added=0
    local expected=$((base_count + ours_added + theirs_added))

    info "Entity count: base=$base_count, ours_added=$ours_added, theirs_added=$theirs_added, merged=$merged_count, expected=$expected"

    if [[ $merged_count -lt $expected ]]; then
        error "MERGE BLOCKED: entity count dropped in $file_path (expected $expected, got $merged_count)"
        return 1
    fi

    return 0
}

# ─── Merge Strategy Config ───────────────────────────────────────

# Strategy arrays — populated by load_merge_strategies()
declare -a STRATEGY_NAMES=()
declare -a STRATEGY_PATTERNS=()
declare -a STRATEGY_TYPES=()
declare -a STRATEGY_ENTITY_PATTERNS=()
declare -a STRATEGY_VALIDATE_CMDS=()
declare -a STRATEGY_LLM_HINTS=()

# Load merge strategies from project-knowledge.yaml or profile fallback.
load_merge_strategies() {
    local project_path="${1:-.}"
    local pk_file="$project_path/project-knowledge.yaml"
    local profile_file="$project_path/.wt-tools/.merge-strategies.json"

    # Try project-knowledge.yaml first
    if [[ -f "$pk_file" ]]; then
        local strategies_json
        strategies_json=$(python3 -c "
import yaml, json, sys
try:
    with open('$pk_file') as f:
        data = yaml.safe_load(f) or {}
    strategies = data.get('merge_strategies', [])
    if strategies:
        json.dump(strategies, sys.stdout)
    else:
        sys.exit(1)
except Exception:
    sys.exit(1)
" 2>/dev/null) && {
            _parse_strategies_json "$strategies_json"
            return 0
        }
    fi

    # Fallback to profile defaults
    if [[ -f "$profile_file" ]]; then
        _parse_strategies_json "$(cat "$profile_file")"
        return 0
    fi

    # No strategies configured — conservation-only mode
    return 0
}

# Parse JSON array of strategies into bash arrays.
_parse_strategies_json() {
    local json="$1"
    local count
    count=$(echo "$json" | jq 'length' 2>/dev/null) || return 1

    for ((i=0; i<count; i++)); do
        STRATEGY_NAMES+=("$(echo "$json" | jq -r ".[$i].name // \"strategy-$i\"")")
        STRATEGY_PATTERNS+=("$(echo "$json" | jq -r ".[$i].patterns | join(\"|\")")")
        STRATEGY_TYPES+=("$(echo "$json" | jq -r ".[$i].strategy // \"llm_with_conservation\"")")
        STRATEGY_ENTITY_PATTERNS+=("$(echo "$json" | jq -r ".[$i].entity_pattern // \"\"")")
        STRATEGY_VALIDATE_CMDS+=("$(echo "$json" | jq -r ".[$i].validate_command // \"\"")")
        STRATEGY_LLM_HINTS+=("$(echo "$json" | jq -r ".[$i].llm_hint // \"\"")")
    done
}

# Find matching strategy for a file. Returns strategy index or empty.
match_strategy() {
    local file_path="$1"
    local basename
    basename=$(basename "$file_path")

    for ((i=0; i<${#STRATEGY_NAMES[@]}; i++)); do
        local patterns="${STRATEGY_PATTERNS[$i]}"
        IFS='|' read -ra pats <<< "$patterns"
        for pat in "${pats[@]}"; do
            # Match full path or basename against glob
            # shellcheck disable=SC2254
            if [[ "$file_path" == ${pat} || "$basename" == ${pat} ]]; then
                echo "$i"
                return 0
            fi
        done
    done
    return 1
}

# Get LLM hint for a file (from strategy config).
get_llm_hint() {
    local file_path="$1"
    local idx
    idx=$(match_strategy "$file_path" 2>/dev/null) || return 1

    local hint="${STRATEGY_LLM_HINTS[$idx]}"
    local strategy_type="${STRATEGY_TYPES[$idx]}"

    if [[ -n "$hint" ]]; then
        echo "Merge strategy: $strategy_type"
        echo "$hint"
        if [[ "$strategy_type" == "additive" ]]; then
            echo "This file uses additive merge — NEVER remove entities from either side."
        fi
        return 0
    fi

    # Fallback: path-based role hints when no strategy config exists
    case "$file_path" in
        *.test.* | *.spec.* | *__tests__/*) echo "TEST file — prefer source branch (feature tests)" ;;
        prisma/* | *.prisma) echo "DATABASE SCHEMA — merge both model definitions, keep all models" ;;
        src/app/* | src/pages/* | app/*) echo "PAGE/ROUTE — prefer source branch (new feature page)" ;;
        *.config.* | next.config.* | tailwind.*) echo "CONFIG — use target as base, add source's new entries" ;;
        src/components/*) echo "COMPONENT — prefer source unless target has critical fixes" ;;
        src/lib/* | src/utils/* | lib/*) echo "SHARED LIBRARY — keep both sides, resolve import conflicts" ;;
        *) return 1 ;;
    esac
}

# Run post-merge validation commands for LLM-resolved files.
# Args: (none — uses LLM_RESOLVED_FILES and strategy arrays)
# Returns 0 if all pass, 1 if any fail.
run_validation_commands() {
    local failed=false

    for file_path in "${LLM_RESOLVED_FILES[@]}"; do
        local idx
        idx=$(match_strategy "$file_path" 2>/dev/null) || continue

        local validate_cmd="${STRATEGY_VALIDATE_CMDS[$idx]}"
        [[ -z "$validate_cmd" ]] && continue

        info "Running validation for $file_path: $validate_cmd"
        local output rc=0
        output=$(bash -c "$validate_cmd" 2>&1) || rc=$?

        if [[ $rc -ne 0 ]]; then
            error "MERGE BLOCKED: validation failed for $file_path"
            echo "  Command: $validate_cmd"
            echo "  Output: $(echo "$output" | tail -5)"
            failed=true
        fi
    done

    if $failed; then
        return 1
    fi
    return 0
}

# Run entity count checks for files with additive strategy.
# Args: merge_base, ours_ref, theirs_ref
# Returns 0 if all pass, 1 if any fail.
run_entity_checks() {
    local merge_base="$1"
    local ours_ref="$2"
    local theirs_ref="$3"

    local failed=false

    for file_path in "${LLM_RESOLVED_FILES[@]}"; do
        local idx
        idx=$(match_strategy "$file_path" 2>/dev/null) || continue

        local strategy_type="${STRATEGY_TYPES[$idx]}"
        local entity_pattern="${STRATEGY_ENTITY_PATTERNS[$idx]}"

        if [[ "$strategy_type" == "additive" && -n "$entity_pattern" ]]; then
            if ! entity_count_check "$merge_base" "$ours_ref" "$theirs_ref" "$file_path" "$entity_pattern"; then
                failed=true
            fi
        fi
    done

    if $failed; then
        return 1
    fi
    return 0
}

main() {
    local change_id=""
    local project_name=""
    local target_branch=""
    local squash=false
    local delete_branch=true
    local push_after=true
    local llm_resolve=false
    local conservation_check=true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--project)
                project_name="$2"
                shift 2
                ;;
            --to)
                target_branch="$2"
                shift 2
                ;;
            --squash)
                squash=true
                shift
                ;;
            --no-delete)
                delete_branch=false
                shift
                ;;
            --no-push)
                push_after=false
                shift
                ;;
            --llm-resolve)
                llm_resolve=true
                shift
                ;;
            --no-conservation-check)
                conservation_check=false
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
            *)
                if [[ -z "$change_id" ]]; then
                    change_id="$1"
                else
                    error "Unexpected argument: $1"
                    usage
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$change_id" ]]; then
        error "Change ID required"
        usage
        exit 1
    fi

    # Resolve project
    local resolved_project
    resolved_project=$(resolve_project "$project_name") || exit 1

    local project_path
    project_path=$(get_project_path "$resolved_project")

    # Find existing worktree
    local wt_path
    wt_path=$(find_existing_worktree "$project_path" "$change_id")

    if [[ -z "$wt_path" || ! -d "$wt_path" ]]; then
        error "Worktree not found for: $change_id"
        exit 1
    fi

    # Get branch name from worktree
    local source_branch
    source_branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null)

    if [[ -z "$source_branch" ]]; then
        error "Could not determine branch for worktree"
        exit 1
    fi

    # Determine target branch
    if [[ -z "$target_branch" ]]; then
        target_branch=$(find_default_branch "$project_path")
        if [[ -z "$target_branch" ]]; then
            error "Could not find default branch (main/master). Use --to <branch>"
            exit 1
        fi
    fi

    # Verify target branch exists
    if ! git -C "$project_path" show-ref --verify --quiet "refs/heads/$target_branch" 2>/dev/null; then
        error "Target branch '$target_branch' does not exist"
        exit 1
    fi

    # Check for uncommitted changes in worktree (auto-stash generated files)
    local changes
    changes=$(git -C "$wt_path" status --porcelain 2>/dev/null | grep -v "^?? \.zed/" | grep -v "^?? " || true)
    if [[ -n "$changes" ]]; then
        # Filter: are all changes in generated files?
        local non_generated=false
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local file="${line:3}"  # strip status prefix
            if ! is_generated_file "$file"; then
                non_generated=true
                break
            fi
        done <<< "$changes"

        if $non_generated; then
            # Auto-commit remaining changes (the verify gate already approved them)
            info "Worktree has uncommitted changes — auto-committing before merge"
            git -C "$wt_path" add -A 2>/dev/null || true
            git -C "$wt_path" commit -m "chore: auto-commit remaining changes before merge" --no-verify 2>/dev/null || true
            # Re-check if clean now
            changes=$(git -C "$wt_path" status --porcelain 2>/dev/null | grep -v "^?? \.zed/" | grep -v "^?? " || true)
            if [[ -n "$changes" ]]; then
                error "Worktree still has uncommitted changes after auto-commit."
                echo ""
                echo "$changes"
                exit 1
            fi
        else
            # Auto-stash generated file changes
            git -C "$wt_path" stash --quiet 2>/dev/null || true
            info "Auto-stashed generated file changes in worktree"
        fi
    fi

    # Auto-stash any uncommitted changes in main repo before merge.
    # This prevents false merge failures from worktree artifacts (.wt/reflection.md, .claude/reflection.md),
    # generated files (tsconfig.tsbuildinfo), or orchestrator state files.
    local main_changes
    main_changes=$(git -C "$project_path" status --porcelain 2>/dev/null | grep -v "^?? " || true)
    if [[ -n "$main_changes" ]]; then
        git -C "$project_path" stash --quiet 2>/dev/null || true
        info "Auto-stashed uncommitted changes in main repo"
    fi

    # Pre-merge: clean runtime files from the worktree branch
    if cleanup_runtime_files "$wt_path"; then
        info "Pre-merge: cleaned runtime files from worktree index"
        git -C "$wt_path" commit -m "chore: remove runtime files from git tracking" --no-verify 2>/dev/null || true
    fi

    info "Merging '$source_branch' into '$target_branch'..."
    echo "  Project: $resolved_project"
    echo "  Source: $source_branch"
    echo "  Target: $target_branch"
    if $squash; then
        echo "  Mode: squash"
    fi

    # Go to project root and checkout target branch
    cd "$project_path" || exit 1

    # Fetch latest
    git fetch origin "$target_branch" 2>/dev/null || true

    # Checkout target branch
    git checkout "$target_branch"
    if [[ $? -ne 0 ]]; then
        error "Failed to checkout '$target_branch'"
        exit 1
    fi

    # Pull latest
    git pull origin "$target_branch" 2>/dev/null || true

    # Merge (|| true to prevent set -e from killing on conflict)
    local merge_result=0
    local merge_stderr
    merge_stderr=$(mktemp)
    if $squash; then
        git merge --squash "$source_branch" 2>"$merge_stderr" || merge_result=$?
        if [[ $merge_result -eq 0 ]]; then
            git commit -m "Squashed merge of '$source_branch'" || merge_result=$?
        fi
    else
        git merge "$source_branch" -m "Merge '$source_branch' into '$target_branch'" 2>"$merge_stderr" || merge_result=$?
    fi

    # Handle "untracked working tree files would be overwritten by merge"
    if [[ $merge_result -ne 0 ]] && grep -q "untracked working tree files would be overwritten" "$merge_stderr" 2>/dev/null; then
        # Extract the blocking file list from stderr
        local blocking_files
        blocking_files=$(grep -A 100 "untracked working tree files would be overwritten" "$merge_stderr" | grep $'^\t' | sed 's/^\t//')
        if [[ -n "$blocking_files" ]]; then
            warn "Untracked files blocking merge — removing them:"
            while IFS= read -r f; do
                # Never delete orchestration state files — they belong to the running orchestrator
                if [[ "$f" == orchestration-state* || "$f" == orchestration-plan* || "$f" == orchestration-events* || "$f" == orchestration.log ]]; then
                    info "  preserving orchestration file: $f"
                    git add "$f" 2>/dev/null || true
                    continue
                fi
                info "  removing untracked: $f"
                rm -f "$f"
            done <<< "$blocking_files"
            # Retry merge
            merge_result=0
            if $squash; then
                git merge --squash "$source_branch" 2>/dev/null || merge_result=$?
                if [[ $merge_result -eq 0 ]]; then
                    git commit -m "Squashed merge of '$source_branch'" || merge_result=$?
                fi
            else
                git merge "$source_branch" -m "Merge '$source_branch' into '$target_branch'" 2>/dev/null || merge_result=$?
            fi
        fi
    fi
    rm -f "$merge_stderr"

    if [[ $merge_result -ne 0 ]]; then
        # Check if conflicts are only in auto-resolvable generated files
        local conflicted_files
        conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)

        # Always resolve generated files in partial mode — lockfiles and .claude/* runtime
        # files are auto-resolved regardless of whether app code conflicts also exist.
        # Without this, a single app file conflict prevents lockfile auto-resolution,
        # and the LLM gets a 10K-line pnpm-lock.yaml it can't resolve.
        local partial_mode="true"

        if [[ -n "$conflicted_files" ]] && auto_resolve_generated_files "$conflicted_files" "$partial_mode"; then
            # All conflicts were in generated files and have been resolved
            git commit --no-edit 2>/dev/null
            merge_result=$?
        fi

        # Try programmatic package.json merge before expensive LLM resolution
        if [[ $merge_result -ne 0 ]]; then
            conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
            if [[ -n "$conflicted_files" ]]; then
                auto_resolve_package_json "$conflicted_files" "$source_branch" "$target_branch" || true
                # Re-check if conflicts remain
                conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
                if [[ -z "$conflicted_files" ]]; then
                    git commit --no-edit 2>/dev/null
                    merge_result=$?
                fi
            fi
        fi

        # Try programmatic JSON file merge (translation files, config, etc.)
        if [[ $merge_result -ne 0 ]]; then
            conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
            if [[ -n "$conflicted_files" ]]; then
                auto_resolve_json_files "$conflicted_files" "$source_branch" "$target_branch" || true
                # Re-check if conflicts remain
                conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
                if [[ -z "$conflicted_files" ]]; then
                    git commit --no-edit 2>/dev/null
                    merge_result=$?
                fi
            fi
        fi

        # Try structural conflict resolution (delete/modify, rename)
        if [[ $merge_result -ne 0 ]]; then
            conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
            if [[ -n "$conflicted_files" ]]; then
                auto_resolve_structural_conflicts "$conflicted_files" || true
                # Re-check if conflicts remain
                conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
                if [[ -z "$conflicted_files" ]]; then
                    git commit --no-edit 2>/dev/null
                    merge_result=$?
                fi
            fi
        fi

        # Try LLM resolution for remaining conflicts
        if [[ $merge_result -ne 0 ]] && $llm_resolve; then
            conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
            if [[ -n "$conflicted_files" ]]; then
                # Load merge strategies for LLM hint enrichment
                load_merge_strategies "$(pwd)"

                if llm_resolve_conflicts "$source_branch" "$target_branch" "$conflicted_files"; then
                    # ── Post-LLM integrity checks (BEFORE commit) ──
                    local integrity_ok=true

                    if $conservation_check; then
                        # Compute merge-base for conservation checks
                        local check_merge_base
                        check_merge_base=$(git merge-base "$target_branch" "$source_branch" 2>/dev/null || echo "")

                        if [[ -n "$check_merge_base" ]]; then
                            # Pre-merge HEAD ref (the target branch before merge started)
                            local ours_ref="$target_branch"
                            local theirs_ref="$source_branch"

                            # Layer 1: Entity count checks (additive strategy files)
                            if ! run_entity_checks "$check_merge_base" "$ours_ref" "$theirs_ref"; then
                                integrity_ok=false
                            fi

                            # Layer 2: Generic conservation check (all LLM-resolved files)
                            if $integrity_ok && ! run_conservation_checks "$check_merge_base" "$ours_ref" "$theirs_ref"; then
                                integrity_ok=false
                            fi

                            # Layer 3: Validation commands (per-strategy)
                            if $integrity_ok && ! run_validation_commands; then
                                integrity_ok=false
                            fi
                        else
                            warn "Could not compute merge-base — skipping conservation checks"
                        fi
                    fi

                    if $integrity_ok; then
                        git commit --no-edit 2>/dev/null
                        merge_result=$?
                    else
                        # Abort the uncommitted merge
                        error "Integrity checks failed — aborting merge"
                        git reset --merge 2>/dev/null || git checkout -- . 2>/dev/null || true
                        merge_result=1
                    fi
                fi
            fi
        fi

        if [[ $merge_result -ne 0 ]]; then
            git merge --abort 2>/dev/null || true
            # Restore stashed changes before exiting
            if [[ -n "$main_changes" ]]; then
                git stash pop --quiet 2>/dev/null || true
            fi
            error "Merge failed! Resolve conflicts manually."
            echo ""
            echo "After resolving:"
            echo "  git add ."
            echo "  git commit"
            echo "  wt-close $change_id"
            exit 1
        fi
    fi

    # Restore stashed changes after successful merge
    if [[ -n "$main_changes" ]]; then
        git stash pop --quiet 2>/dev/null || true
    fi

    success "Merge completed successfully"

    # Push merged target branch to origin
    if $push_after; then
        info "Pushing '$target_branch' to origin..."
        if git push origin "$target_branch"; then
            success "Pushed to origin/$target_branch"
        else
            warn "Failed to push to origin. Push manually: git push origin $target_branch"
        fi
    fi

    # Delete source branch if requested
    if $delete_branch; then
        echo ""
        info "Deleting source branch '$source_branch'..."
        if git branch -d "$source_branch" 2>/dev/null; then
            success "Branch '$source_branch' deleted"
        elif git branch -D "$source_branch" 2>/dev/null; then
            # Force delete if not fully merged (squash case)
            success "Branch '$source_branch' deleted (force)"
        else
            warn "Could not delete branch (still checked out in worktree)"
            echo "  Branch will be deleted when you run: wt-close $change_id"
        fi
    fi

    echo ""
    success "Done! Close the worktree with:"
    echo "  wt-close $change_id"
}

main "$@"
