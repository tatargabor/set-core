#!/usr/bin/env python3
"""set-supervisor — Python daemon that supervises a set-orchestrate run.

Phase 1 MVP: starts the orchestrator, monitors its lifetime, restarts on
crash, handles user inbox, emits observability events. No anomaly
detection and no ephemeral Claude triggers yet — those come in Phase 2.

Usage:
    set-supervisor --project <path> --spec <path>
    set-supervisor --project . --spec docs/spec.md

Typically invoked by the set-web manager API in response to
POST /api/<project>/sentinel/start when the directive
`supervisor_mode: python` is set (the default).
"""

import argparse
import logging
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "lib"))

from set_orch.supervisor import SupervisorConfig, SupervisorDaemon


def _setup_logging(level: str) -> None:
    logging.basicConfig(
        level=getattr(logging, level.upper(), logging.INFO),
        format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
        stream=sys.stderr,
    )


def main() -> int:
    parser = argparse.ArgumentParser(
        description="set-supervisor — Python daemon for set-orchestrate",
    )
    parser.add_argument(
        "--project", required=True,
        help="Absolute path to the project root (orchestration-state.json location)",
    )
    parser.add_argument(
        "--spec", required=True,
        help="Spec file path (relative to project root) — e.g. docs/spec.md",
    )
    parser.add_argument(
        "--orch-binary", default="set-orchestrate",
        help="Orchestrator binary to spawn (default: set-orchestrate)",
    )
    parser.add_argument(
        "--poll-interval", type=int, default=15,
        help="Seconds between poll cycles (default: 15)",
    )
    parser.add_argument(
        "--log-level", default="INFO",
        help="Python logging level (default: INFO)",
    )
    parser.add_argument(
        "orch_extra_args", nargs=argparse.REMAINDER,
        help="Extra args passed through to set-orchestrate",
    )
    args = parser.parse_args()

    _setup_logging(args.log_level)

    project_path = os.path.abspath(args.project)
    if not os.path.isdir(project_path):
        print(f"[error] project path does not exist: {project_path}", file=sys.stderr)
        return 2

    # Drop the leading `--` if argparse.REMAINDER captured it
    extra_args = args.orch_extra_args or []
    if extra_args and extra_args[0] == "--":
        extra_args = extra_args[1:]

    config = SupervisorConfig(
        project_path=project_path,
        spec=args.spec,
        orch_binary=args.orch_binary,
        orch_extra_args=extra_args,
        poll_interval=args.poll_interval,
    )
    daemon = SupervisorDaemon(config)
    return daemon.run()


if __name__ == "__main__":
    sys.exit(main())
