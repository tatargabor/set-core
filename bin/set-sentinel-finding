#!/usr/bin/env python3
"""CLI for sentinel findings management.

Usage:
    set-sentinel-finding add --severity bug --change NAME --summary TEXT [--detail TEXT] [--iteration N]
    set-sentinel-finding update ID --status fixed [--commit HASH]
    set-sentinel-finding list [--open-only]
    set-sentinel-finding assess --scope SCOPE --summary TEXT [--recommendation TEXT]
"""

import argparse
import json
import logging
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "lib"))

from set_orch.sentinel.events import SentinelEventLogger
from set_orch.sentinel.findings import SentinelFindings


def main():
    logging.basicConfig(level=logging.INFO, format="%(name)s %(levelname)s: %(message)s")
    parser = argparse.ArgumentParser(description="Sentinel findings management")
    parser.add_argument("--project", default=os.getcwd(), help="Project path")
    sub = parser.add_subparsers(dest="command", required=True)

    # add
    p = sub.add_parser("add", help="Add a new finding")
    p.add_argument("--severity", required=True, choices=["bug", "observation", "pattern", "regression"])
    p.add_argument("--change", required=True)
    p.add_argument("--summary", required=True)
    p.add_argument("--detail", default="")
    p.add_argument("--iteration", type=int, default=None)

    # update
    p = sub.add_parser("update", help="Update a finding")
    p.add_argument("finding_id", help="Finding ID (e.g., F001)")
    p.add_argument("--status", help="New status (open, fixed, dismissed)")
    p.add_argument("--commit", help="Fix commit hash")

    # list
    p = sub.add_parser("list", help="List findings")
    p.add_argument("--open-only", action="store_true", help="Only show open findings")

    # assess
    p = sub.add_parser("assess", help="Add an assessment")
    p.add_argument("--scope", required=True, help="Assessment scope (e.g., phase-2)")
    p.add_argument("--summary", required=True)
    p.add_argument("--recommendation", default="")

    args = parser.parse_args()

    event_logger = SentinelEventLogger(args.project)
    findings = SentinelFindings(args.project, event_logger=event_logger)

    if args.command == "add":
        result = findings.add(
            severity=args.severity,
            change=args.change,
            summary=args.summary,
            detail=args.detail,
            iteration=args.iteration,
        )
        print(json.dumps(result, indent=2))

    elif args.command == "update":
        updates = {}
        if args.status:
            updates["status"] = args.status
        if args.commit:
            updates["commit"] = args.commit
        result = findings.update(args.finding_id, **updates)
        if result:
            print(json.dumps(result, indent=2))
        else:
            print(f"Finding {args.finding_id} not found", file=sys.stderr)
            sys.exit(1)

    elif args.command == "list":
        status_filter = "open" if args.open_only else None
        results = findings.list(status=status_filter)
        for f in results:
            severity_icon = {"bug": "🔴", "observation": "🟡", "pattern": "🔵", "regression": "🔴"}.get(f["severity"], "⚪")
            print(f'{severity_icon} {f["id"]}  [{f["severity"]}]  {f["change"]}  {f["summary"]}  ({f["status"]})')

    elif args.command == "assess":
        result = findings.assess(
            scope=args.scope,
            summary=args.summary,
            recommendation=args.recommendation,
        )
        print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
