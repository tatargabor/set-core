#!/usr/bin/env bash
# set-project - Manage project registry for set-core

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/set-common.sh"

# Resolve set-core repo root (follow symlinks to find the real bin dir)
_wt_project_script="${BASH_SOURCE[0]}"
while [[ -L "$_wt_project_script" ]]; do
    _link=$(readlink "$_wt_project_script")
    if [[ "$_link" == /* ]]; then _wt_project_script="$_link"; else _wt_project_script="$(dirname "$_wt_project_script")/$_link"; fi
done
SET_TOOLS_ROOT="$(cd "$(dirname "$_wt_project_script")/.." && pwd)"

# Source deploy functions from lib/project/
source "$SET_TOOLS_ROOT/lib/project/deploy.sh"

# Get set-core version (git short hash or tag)
_get_set_tools_version() {
    local version=""
    if [[ -d "$SET_TOOLS_ROOT/.git" ]] || git -C "$SET_TOOLS_ROOT" rev-parse --git-dir &>/dev/null; then
        # Prefer tag if on a tagged commit
        version=$(git -C "$SET_TOOLS_ROOT" describe --tags --exact-match 2>/dev/null || true)
        if [[ -z "$version" ]]; then
            version=$(git -C "$SET_TOOLS_ROOT" rev-parse --short HEAD 2>/dev/null || true)
        fi
    fi
    echo "${version:-unknown}"
}

# Find a Python 3 interpreter that has set-project-base installed.
# Tries: miniconda, uv-managed, system python3 — returns first that works.
_set_python() {
    # Find a working Python 3 interpreter with yaml support.
    # Prefers brew python (has yaml) over system python (often lacks it).
    local candidates=(
        "/opt/homebrew/bin/python3.12"
        "/opt/homebrew/bin/python3"
        "$(command -v python3.12 2>/dev/null)"
        "$(command -v python3.11 2>/dev/null)"
        "$(command -v python3.10 2>/dev/null)"
        "$(command -v python3 2>/dev/null)"
        "$HOME/miniconda3/bin/python"
        "$HOME/.local/share/uv/python/cpython-*/bin/python3"
        "$(command -v python 2>/dev/null)"
    )
    for py in "${candidates[@]}"; do
        [[ -z "$py" ]] && continue
        for resolved in $py; do
            [[ -x "$resolved" ]] || continue
            if "$resolved" -c "import sys, yaml; assert sys.version_info >= (3, 10)" 2>/dev/null; then
                echo "$resolved"
                return 0
            fi
        done
    done
    # Fallback: any python3 >= 3.9 (yaml may be missing)
    for py in "$(command -v python3 2>/dev/null)" "$(command -v python 2>/dev/null)"; do
        [[ -z "$py" || ! -x "$py" ]] && continue
        if "$py" -c "import sys; assert sys.version_info >= (3, 9)" 2>/dev/null; then
            echo "$py"
            return 0
        fi
    done
    echo "python3"
}

# Known orchestration directives with defaults (for migration additive merge)
_KNOWN_DIRECTIVES='{"max_parallel":2,"default_model":"opus","time_limit":"","checkpoint_interval":5,"smoke_command":"","smoke_timeout":120,"smoke_blocking":true,"test_command":"","build_command":"","review_model":"","events_log":"","events_max_size":"","watchdog_timeout":"","watchdog_loop_threshold":"","max_tokens_per_change":"","context_pruning":true,"plan_approval":false,"model_routing":"off"}'

# Migrate consumer project on version change — additive only, never overwrites.
# Usage: _migrate_consumer <project-path> <old-version> <new-version>
_migrate_consumer() {
    local project_path="$1"
    local old_ver="$2"
    local new_ver="$3"
    local added_directives=0
    local created_files=0

    # 1. Additive directive merge for orchestration.yaml (check set/ first)
    local orch_yaml="$project_path/set/orchestration/config.yaml"
    if [[ ! -f "$orch_yaml" ]]; then
        orch_yaml="$project_path/.claude/orchestration.yaml"
    fi
    if [[ -f "$orch_yaml" ]]; then
        # Find directives in our known set that are missing from consumer's yaml
        local existing_keys
        existing_keys=$(grep -E '^[a-z_]+:' "$orch_yaml" 2>/dev/null | sed 's/:.*//' | tr '\n' '|' || true)

        if [[ -n "$existing_keys" ]]; then
            # Check each known directive
            local all_keys
            all_keys=$(echo "$_KNOWN_DIRECTIVES" | jq -r 'keys[]')
            while IFS= read -r key; do
                [[ -z "$key" ]] && continue
                if ! echo "$existing_keys" | grep -q "${key}|"; then
                    # Missing directive — add with comment
                    local default_val
                    default_val=$(echo "$_KNOWN_DIRECTIVES" | jq -r --arg k "$key" '.[$k] // ""')
                    if [[ "$DRY_RUN" == "true" ]]; then
                        info "  Would add directive: $key: $default_val"
                    else
                        echo "# $key: $default_val  # added by migration $old_ver → $new_ver" >> "$orch_yaml"
                    fi
                    added_directives=$((added_directives + 1))
                fi
            done <<< "$all_keys"
        fi
    fi

    # 2. Scaffold project-knowledge.yaml if missing
    local pk_file="$project_path/project-knowledge.yaml"
    if [[ ! -f "$pk_file" && -f "$SET_TOOLS_ROOT/templates/project-knowledge.yaml" ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            info "  Would scaffold project-knowledge.yaml"
        else
            # Don't auto-create — just inform. Use init-knowledge for proper scaffolding
            info "  project-knowledge.yaml missing — run 'set-project init-knowledge' to scaffold"
        fi
        created_files=$((created_files + 1))
    fi

    # 3. Warn about unknown or deprecated directives
    if [[ -f "$orch_yaml" ]]; then
        local consumer_keys
        consumer_keys=$(grep -E '^[a-z_]+:' "$orch_yaml" 2>/dev/null | sed 's/:.*//' || true)
        local known_keys
        known_keys=$(echo "$_KNOWN_DIRECTIVES" | jq -r 'keys[]')
        # Also allow hook_* directives
        while IFS= read -r ckey; do
            [[ -z "$ckey" ]] && continue
            [[ "$ckey" == hook_* ]] && continue  # hook_* are valid
            if ! echo "$known_keys" | grep -qx "$ckey"; then
                warn "  Unknown directive in orchestration.yaml: $ckey"
            fi
        done <<< "$consumer_keys"
    fi

    if [[ $added_directives -gt 0 || $created_files -gt 0 ]]; then
        local verb="Updated"
        [[ "$DRY_RUN" == "true" ]] && verb="Would update"
        info "  $verb from $old_ver to $new_ver: added $added_directives directive(s), created $created_files file(s)"
    fi
}

# Deploy set-core hooks, commands, and skills to a project's .claude/ directory.
# Usage: deploy_set_tools <project-path> [<extra-mcp-path> ...]
# extra-mcp-path: additional paths to register MCP for (e.g. current worktree)
# Write set/plugins/.generated-file-patterns from profile for bash consumption (set-merge).
# One pattern per line. No-op if no profile or profile returns empty list.
_write_generated_file_patterns() {
    local project_path="$1"
    local patterns_file="$project_path/set/plugins/.generated-file-patterns"

    # set/plugins/ must exist (scaffold_set_directory creates it)
    [[ -d "$project_path/set/plugins" ]] || return 0

    local py
    py=$(_set_python) 2>/dev/null || return 0

    set_python "$py" -c "
import sys
project_path = sys.argv[1]
output_file = sys.argv[2]
try:
    from set_orch.profile_loader import load_profile, NullProfile
    profile = load_profile(project_path)
    if isinstance(profile, NullProfile):
        sys.exit(0)
    patterns = profile.generated_file_patterns()
    if not patterns:
        sys.exit(0)
    with open(output_file, 'w') as f:
        for p in patterns:
            f.write(p + '\n')
except Exception:
    sys.exit(0)  # graceful — bash uses hardcoded fallback
" "$project_path" "$patterns_file" 2>/dev/null || true
}

deploy_set_tools() {
    local project_path="$1"
    shift
    local claude_dir="$project_path/.claude"
    local _warnings=0

    # 0. Version tracking — store set-core version in consumer project
    local current_version
    current_version=$(_get_set_tools_version)
    local version_file="$claude_dir/.set-version"
    local old_version=""
    if [[ -f "$version_file" ]]; then
        old_version=$(cat "$version_file" 2>/dev/null || true)
    fi
    mkdir -p "$claude_dir"
    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ -n "$old_version" && "$old_version" != "$current_version" ]]; then
            info "  Would update set-core: $old_version → $current_version"
            _migrate_consumer "$project_path" "$old_version" "$current_version"
        elif [[ -z "$old_version" ]]; then
            info "  Would write version: $current_version"
        fi
        return 0
    fi
    echo "$current_version" > "$version_file"
    if [[ -n "$old_version" && "$old_version" != "$current_version" ]]; then
        info "  set-core updated: $old_version → $current_version"
        _migrate_consumer "$project_path" "$old_version" "$current_version"
    fi

    # Deploy each subsystem via focused functions (from lib/project/deploy.sh)
    _deploy_hooks "$project_path" || ((_warnings++)) || true
    _deploy_commands "$project_path"
    _deploy_skills "$project_path"
    _deploy_memory "$project_path"
    scaffold_set_directory "$project_path"
    _deploy_mcp "$project_path" "$@" || ((_warnings++)) || true

    return $(( _warnings > 0 ? 1 : 0 ))
}

# Register the unified set-core MCP server scoped to one or more project paths.
# _register_mcp_server and _cleanup_deprecated_memory_refs moved to lib/project/deploy.sh

# Resolve a project type name via Python entry points.
# Prints JSON with info, rules, and directives.
# Returns 1 if the project type is not found.
_resolve_project_type() {
    local type_name="$1"
    local py
    py=$(_set_python)
    # Use profile_loader's full resolution chain (entry_points → direct import → built-in modules)
    PYTHONPATH="$SET_TOOLS_ROOT/lib:${PYTHONPATH:-}" "$py" -c "
import json, sys, os
sys.path.insert(0, os.path.join(os.environ.get('SET_TOOLS_ROOT', '.'), 'lib'))
type_name = sys.argv[1]

# Try profile_loader's resolution chain first (includes built-in modules/)
try:
    from set_orch.profile_loader import _find_project_type_class, _SET_CORE_ROOT
    import importlib

    # Step 1: entry_points
    try:
        from importlib.metadata import entry_points
        eps = entry_points(group='set_tools.project_types')
    except TypeError:
        eps = entry_points().get('set_tools.project_types', [])

    pt = None
    for ep in eps:
        if ep.name == type_name:
            cls = ep.load()
            pt = cls()
            break

    # Step 2: direct import
    if pt is None:
        try:
            mod = importlib.import_module(f'set_project_{type_name}')
            cls = _find_project_type_class(mod)
            if cls:
                pt = cls()
        except ImportError:
            pass

    # Step 3: built-in modules/
    if pt is None:
        modules_dir = _SET_CORE_ROOT / 'modules' / type_name
        module_pkg = modules_dir / f'set_project_{type_name}'
        if module_pkg.is_dir():
            sys.path.insert(0, str(modules_dir))
            try:
                mod = importlib.import_module(f'set_project_{type_name}')
                cls = _find_project_type_class(mod)
                if cls:
                    pt = cls()
            except ImportError:
                pass

    if pt is None:
        print(json.dumps({'error': 'not_found'}), file=sys.stderr)
        sys.exit(1)

    info = pt.info
    rules = [{'id': r.id, 'description': r.description, 'check': r.check, 'severity': r.severity} for r in pt.get_verification_rules()]
    directives = [{'id': d.id, 'description': d.description, 'trigger': d.trigger, 'action': d.action} for d in pt.get_orchestration_directives()]
    print(json.dumps({'name': info.name, 'version': info.version, 'description': info.description, 'parent': getattr(info, 'parent', None), 'rules_count': len(rules), 'directives_count': len(directives)}))
except Exception as e:
    print(json.dumps({'error': str(e)}), file=sys.stderr)
    sys.exit(1)
" "$type_name" 2>/dev/null
}

# List available project types via Python entry points.
_list_project_types() {
    local py
    py=$(_set_python)
    PYTHONPATH="$SET_TOOLS_ROOT/lib:${PYTHONPATH:-}" "$py" -c "
import sys, os
sys.path.insert(0, os.path.join(os.environ.get('SET_TOOLS_ROOT', '.'), 'lib'))
from pathlib import Path

found = set()

# Step 1: entry_points (external plugins)
try:
    from importlib.metadata import entry_points
    eps = entry_points(group='set_tools.project_types')
except TypeError:
    eps = entry_points().get('set_tools.project_types', [])

for ep in eps:
    try:
        cls = ep.load()
        pt = cls()
        info = pt.info
        print(f'  {ep.name:12s} — {info.description}')
        found.add(ep.name)
    except Exception as e:
        print(f'  {ep.name:12s} — (failed to load: {e})', file=sys.stderr)

# Step 2: built-in modules/
set_core_root = Path(os.environ.get('SET_TOOLS_ROOT', '.')).resolve()
modules_dir = set_core_root / 'modules'
if modules_dir.is_dir():
    for mod_dir in sorted(modules_dir.iterdir()):
        if not mod_dir.is_dir():
            continue
        type_name = mod_dir.name
        if type_name in found:
            continue
        pkg_dir = mod_dir / f'set_project_{type_name}'
        if not (pkg_dir / '__init__.py').is_file():
            continue
        try:
            sys.path.insert(0, str(mod_dir))
            import importlib
            mod = importlib.import_module(f'set_project_{type_name}')
            from set_orch.profile_loader import _find_project_type_class
            cls = _find_project_type_class(mod)
            if cls:
                pt = cls()
                info = pt.info
                print(f'  {type_name:12s} — {info.description} (built-in)')
                found.add(type_name)
        except Exception as e:
            print(f'  {type_name:12s} — (failed to load: {e})', file=sys.stderr)

if not found:
    print('  (no project types found)')
" 2>/dev/null
}

# Save project type to set/plugins/project-type.yaml
_save_project_type() {
    local project_path="$1"
    local type_name="$2"
    local init_template="${3:-}"
    local init_modules="${4:-}"
    local pt_file="$project_path/set/plugins/project-type.yaml"

    # Validate project type exists
    local pt_info
    pt_info=$(_resolve_project_type "$type_name")
    if [[ $? -ne 0 || -z "$pt_info" ]]; then
        warn "  Project type '$type_name' not found. Available types:"
        _list_project_types
        return 1
    fi

    local py
    py=$(_set_python)

    local version description parent rules_count directives_count
    version=$(echo "$pt_info" | "$py" -c "import json,sys; print(json.load(sys.stdin).get('version',''))")
    description=$(echo "$pt_info" | "$py" -c "import json,sys; print(json.load(sys.stdin).get('description',''))")
    parent=$(echo "$pt_info" | "$py" -c "import json,sys; print(json.load(sys.stdin).get('parent','') or '')")
    rules_count=$(echo "$pt_info" | "$py" -c "import json,sys; print(json.load(sys.stdin).get('rules_count',0))")
    directives_count=$(echo "$pt_info" | "$py" -c "import json,sys; print(json.load(sys.stdin).get('directives_count',0))")

    mkdir -p "$(dirname "$pt_file")"

    # Merge managed fields into existing YAML (preserves user customizations)
    "$py" -c "
import yaml, sys, os

pt_file = sys.argv[1]
managed = {
    'type': sys.argv[2],
    'version': sys.argv[3],
    'description': sys.argv[4],
}
parent_val = sys.argv[5]
template_val = sys.argv[6]
modules_val = sys.argv[7]

if parent_val:
    managed['parent'] = parent_val
if template_val:
    managed['template'] = template_val
if modules_val:
    managed['modules'] = [m.strip() for m in modules_val.split(',') if m.strip()]

if os.path.exists(pt_file):
    with open(pt_file) as f:
        data = yaml.safe_load(f) or {}
    # Update only managed fields, preserve everything else
    for k, v in managed.items():
        data[k] = v
    # Remove parent key if empty (base type)
    if not parent_val and 'parent' in data:
        del data['parent']
else:
    data = managed

with open(pt_file, 'w') as f:
    f.write('# Project type configuration — managed by set-project init\n')
    f.write('# Change with: set-project init --project-type <type>\n')
    yaml.dump(data, f, default_flow_style=False, sort_keys=False)
" "$pt_file" "$type_name" "$version" "$description" "$parent" "$init_template" "$init_modules"

    # If new file, append customization docs as comments
    if ! grep -q 'Project Customizations' "$pt_file" 2>/dev/null; then
        cat >> "$pt_file" << 'CUSTOMIZATION'

# ── Project Customizations ──────────────────────────────────────────
# Add, disable, or override rules and directives below.
# These sections are yours — set-project init will not overwrite them.

# custom_rules:
#   - id: my-custom-rule
#     description: "Description of what this rule checks"
#     check: pattern-absence
#     severity: warning
#     config:
#       pattern: "src/**/*.ts"
#       forbidden: "some-pattern"

# disabled_rules:
#   - ghost-button-text

# rule_overrides:
#   file-size-limit:
#     config:
#       max_lines: 600

# custom_directives:
#   - id: run-custom-lint
#     description: "Run custom linter after changes"
#     trigger: 'change-modifies("src/**")'
#     action: post-merge
#     config: { command: "pnpm lint:custom" }

# disabled_directives:
#   - install-deps-python
CUSTOMIZATION
    fi

    success "  Project type set to '$type_name' ($rules_count rules, $directives_count directives)"

    # Also register in projects.json — look up by path, not basename
    if [[ -f "$CONFIG_FILE" ]]; then
        local abs_path
        abs_path=$(cd "$project_path" && pwd)
        local tmp
        tmp=$(mktemp)
        jq --arg path "$abs_path" --arg pt "$type_name" \
            '(.projects | to_entries[] | select(.value.path == $path)) as $e |
             if $e then .projects[$e.key].project_type = $pt else . end' \
            "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
    fi
}

# Migrate old runtime files to shared location (~/.local/share/set-core/<project>/).
# Idempotent — skips if already migrated or source doesn't exist.
_migrate_runtime_to_shared() {
    local project_path="$1"
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Source set-paths to get WT_RUNTIME_DIR
    if [[ ! -f "$script_dir/set-paths" ]]; then
        return 0
    fi
    (cd "$project_path" && source "$script_dir/set-paths" 2>/dev/null) || return 0
    local runtime_dir
    runtime_dir=$(cd "$project_path" && source "$script_dir/set-paths" 2>/dev/null && echo "$WT_RUNTIME_DIR")
    [[ -z "$runtime_dir" ]] && return 0

    local migrated_marker="$runtime_dir/.migrated"
    [[ -f "$migrated_marker" ]] && return 0

    local migrated=0

    # Migrate orchestration state
    for old_state in "$project_path/set/orchestration/orchestration-state.json" "$project_path/wt/orchestration/orchestration-state.json" "$project_path/orchestration-state.json"; do
        if [[ -f "$old_state" && ! -f "$runtime_dir/orchestration/state.json" ]]; then
            mkdir -p "$runtime_dir/orchestration"
            cp "$old_state" "$runtime_dir/orchestration/state.json"
            migrated=1
        fi
    done

    # Migrate events
    for old_events in "$project_path/set/orchestration/orchestration-state-events.jsonl" "$project_path/wt/orchestration/orchestration-state-events.jsonl" "$project_path/orchestration-events.jsonl"; do
        if [[ -f "$old_events" && ! -f "$runtime_dir/orchestration/events.jsonl" ]]; then
            mkdir -p "$runtime_dir/orchestration"
            cp "$old_events" "$runtime_dir/orchestration/events.jsonl"
            migrated=1
        fi
    done

    # Migrate orchestration log
    for old_log in "$project_path/set/orchestration/orchestration.log" "$project_path/wt/orchestration/orchestration.log" "$project_path/.claude/orchestration.log" "$project_path/orchestration.log"; do
        if [[ -f "$old_log" && ! -f "$runtime_dir/logs/orchestration.log" ]]; then
            mkdir -p "$runtime_dir/logs"
            cp "$old_log" "$runtime_dir/logs/orchestration.log"
            migrated=1
        fi
    done

    # Migrate sentinel from .set/sentinel/ to shared
    local old_sentinel="$project_path/.set/sentinel"
    if [[ -d "$old_sentinel" && ! -f "$runtime_dir/sentinel/events.jsonl" ]]; then
        mkdir -p "$runtime_dir/sentinel"
        cp -r "$old_sentinel"/* "$runtime_dir/sentinel/" 2>/dev/null || true
        migrated=1
    fi

    # Migrate sentinel.pid from project root
    if [[ -f "$project_path/sentinel.pid" && ! -f "$runtime_dir/sentinel/sentinel.pid" ]]; then
        mkdir -p "$runtime_dir/sentinel"
        mv "$project_path/sentinel.pid" "$runtime_dir/sentinel/sentinel.pid"
        migrated=1
    fi

    # Migrate design-snapshot
    if [[ -f "$project_path/design-snapshot.md" && ! -f "$runtime_dir/design-snapshot.md" ]]; then
        cp "$project_path/design-snapshot.md" "$runtime_dir/design-snapshot.md"
        migrated=1
    fi

    if [[ $migrated -gt 0 ]]; then
        date -Iseconds > "$migrated_marker"
        echo "Migrated runtime files to $runtime_dir"
    fi
}

# Migrate legacy wt/ directory to set/ (one-time rename).
_migrate_wt_to_set() {
    local project_path="$1"
    if [[ -d "$project_path/wt" && ! -d "$project_path/set" ]]; then
        mv "$project_path/wt" "$project_path/set"
        success "  Migrated wt/ → set/"
        # Update .gitignore
        if [[ -f "$project_path/.gitignore" ]]; then
            sed_i 's|^wt/\.work/$|set/.work/|' "$project_path/.gitignore"
        fi
    fi
}

# Scaffold set/ directory structure in a project.
# Creates all standard subdirectories. Idempotent — safe to re-run.
scaffold_set_directory() {
    local project_path="$1"
    _migrate_wt_to_set "$project_path"
    local set_dir="$project_path/set"

    mkdir -p \
        "$set_dir/orchestration/specs/archive" \
        "$set_dir/knowledge/patterns" \
        "$set_dir/knowledge/lessons" \
        "$set_dir/requirements" \
        "$set_dir/plugins" \
        "$set_dir/.work"

    # Create shared runtime directory (~/.local/share/set-core/<project>/)
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [[ -f "$script_dir/set-paths" ]]; then
        (cd "$project_path" && source "$script_dir/set-paths" 2>/dev/null && wt_ensure_runtime_dirs) || true
    fi

    # Add set/.work/ to .gitignore if not already present
    local gitignore="$project_path/.gitignore"
    if [[ -f "$gitignore" ]]; then
        if ! grep -qx 'set/.work/' "$gitignore" 2>/dev/null; then
            echo 'set/.work/' >> "$gitignore"
        fi
    else
        echo 'set/.work/' > "$gitignore"
    fi

    # Auto-migrate old runtime files to shared location
    _migrate_runtime_to_shared "$project_path"

    # Create .env.example with Resend email config template (if not exists)
    local env_example="$project_path/.env.example"
    if [[ ! -f "$env_example" ]]; then
        cat > "$env_example" <<'ENVEOF'
# set-core email notifications (optional)
# Set notification: email or notification: desktop+email in orchestration config to enable.
# Then fill in the values below and copy this file to .env
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=noreply@yourdomain.com
# RESEND_TO=you@yourdomain.com
ENVEOF
    fi

    # Ensure .env is in .gitignore (credentials must not be committed)
    if [[ -f "$gitignore" ]]; then
        if ! grep -qx '.env' "$gitignore" 2>/dev/null; then
            echo '.env' >> "$gitignore"
        fi
    fi

    success "  Scaffolded set/ directory structure"

    # Detect legacy files and print migration suggestions
    local found_legacy=false
    local legacy_msgs=()
    if [[ -f "$project_path/.claude/orchestration.yaml" ]]; then
        legacy_msgs+=("    .claude/orchestration.yaml → set/orchestration/config.yaml")
        found_legacy=true
    fi
    if [[ -f "$project_path/project-knowledge.yaml" ]]; then
        legacy_msgs+=("    project-knowledge.yaml → set/knowledge/project-knowledge.yaml")
        found_legacy=true
    fi
    if [[ -d "$project_path/docs/orchestration-runs" ]]; then
        legacy_msgs+=("    docs/orchestration-runs/ → set/orchestration/runs/")
        found_legacy=true
    fi
    # Check for legacy spec files (docs/v1.md, docs/v2.md, etc.)
    # Only flag short names like v1.md, v2_something.md — skip descriptive names like v1-minishop.md
    local has_legacy_specs=false
    for f in "$project_path"/docs/v[0-9]*.md; do
        [[ -f "$f" ]] || continue
        local fname
        fname=$(basename "$f")
        # Skip files with descriptive names (contain hyphen after version prefix)
        [[ "$fname" =~ ^v[0-9]+-[a-z] ]] && continue
        has_legacy_specs=true && break
    done
    if $has_legacy_specs; then
        legacy_msgs+=("    docs/v*.md → set/orchestration/specs/archive/")
        found_legacy=true
    fi

    if $found_legacy; then
        echo ""
        info "  Found legacy files that can be migrated:"
        for msg in "${legacy_msgs[@]}"; do
            echo "$msg"
        done
        echo ""
        info "  Run 'set-project migrate' to move them."
    fi
}

usage() {
    cat <<EOF
Usage: set-project <command> [options]

Commands:
  init [--name <name>]    Register current git repo as a project
  init-knowledge          Scaffold project-knowledge.yaml from project scan
  migrate                 Migrate legacy files to set/ directory structure
  list                    List all registered projects
  list-types              List available project types
  remove <name>           Remove a project from registry
  default <name>          Set default project

Options:
  --name <name>           Custom project name (default: directory name)
  --project-type <type>   Set project type (e.g., base, web)
  --template <name>       Template variant to deploy (e.g., nextjs)
  --modules <list>        Comma-separated optional modules (e.g., gdpr,integrations)
  --dry-run               Show what would change without modifying files
  -h, --help              Show this help

Examples:
  cd /path/to/myproject && set-project init
  set-project init --name myproj --project-type web --template nextjs --modules integrations
  set-project init --dry-run
  set-project init-knowledge
  set-project list-types
  set-project list
  set-project default myproj
  set-project remove myproj
EOF
}

DRY_RUN=false

# Deploy template files from a project type into the target project.
# Usage: _deploy_project_templates <project-path> <type-name> [template-name] [modules]
_deploy_project_templates() {
    local project_path="$1"
    local type_name="$2"
    local template_name="${3:-}"
    local modules="${4:-}"
    local py
    py=$(_set_python)

    local cmd=(env "PYTHONPATH=$SET_TOOLS_ROOT/lib:${PYTHONPATH:-}" "$py" -m set_project_base.cli deploy-templates --project-dir "$project_path" --type "$type_name")
    if [[ -n "$template_name" ]]; then
        cmd+=(--template "$template_name")
    fi
    if [[ -n "$modules" ]]; then
        cmd+=(--modules "$modules")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        cmd+=(--dry-run)
    fi
    # Re-init (project already registered) → force overwrite to pick up template updates
    local existing_path
    existing_path=$(get_project_path "$(basename "$project_path")" 2>/dev/null || true)
    if [[ -n "$existing_path" ]]; then
        cmd+=(--force)
    fi

    echo ""
    info "Deploying project templates..."
    "${cmd[@]}" 2>&1
    return $?
}

# Read tracked modules from project-type.yaml
# Usage: _read_tracked_modules <project-path>
# Prints comma-separated module list or empty string
_read_tracked_modules() {
    local project_path="$1"
    local pt_file="$project_path/set/plugins/project-type.yaml"
    [[ -f "$pt_file" ]] || return 0
    grep '^modules:' "$pt_file" &>/dev/null || return 0
    # Extract module list (YAML array to comma-separated; handles "- x" or "  - x")
    awk '/^modules:/{found=1; next} found && /^ *- /{gsub(/^ *- /,""); printf sep $0; sep=","} found && !/^ *- / && !/^$/{exit}' "$pt_file"
}

# Save template and modules to project-type.yaml (update in-place)
# Usage: _save_template_modules <project-path> <template-name> <modules-csv>
_save_template_modules() {
    local project_path="$1"
    local template_name="$2"
    local modules_csv="$3"
    local pt_file="$project_path/set/plugins/project-type.yaml"
    [[ -f "$pt_file" ]] || return 0

    # Use Python for safe YAML update (avoids grep -v destroying other arrays)
    local py
    py=$(_set_python)
    "$py" -c "
import yaml, sys
pt_file, template_name, modules_csv = sys.argv[1], sys.argv[2], sys.argv[3]
with open(pt_file) as f:
    data = yaml.safe_load(f) or {}
if template_name:
    data['template'] = template_name
if modules_csv:
    data['modules'] = [m.strip() for m in modules_csv.split(',') if m.strip()]
elif 'modules' in data:
    del data['modules']
with open(pt_file, 'w') as f:
    yaml.dump(data, f, default_flow_style=False, sort_keys=False)
" "$pt_file" "$template_name" "$modules_csv" 2>/dev/null
}

# List available optional modules for a project type template.
# Usage: _list_available_modules <type-name> [template-name]
# Prints module lines: "  module-id — description"
_list_available_modules() {
    local type_name="$1"
    local template_name="${2:-}"
    local py
    py=$(_set_python)
    "$py" -c "
import sys
type_name = sys.argv[1]
template_name = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None
try:
    from importlib.metadata import entry_points
except ImportError:
    from importlib_metadata import entry_points
try:
    eps = entry_points(group='set_tools.project_types')
except TypeError:
    eps = entry_points().get('set_tools.project_types', [])
for ep in eps:
    if ep.name == type_name:
        cls = ep.load()
        pt = cls()
        from set_orch.profile_deploy import resolve_template, get_available_modules
        try:
            tid, tdir = resolve_template(pt, template_name)
        except ValueError:
            sys.exit(1)
        mods = get_available_modules(tdir)
        for mid, desc in mods.items():
            print(f'  {mid} — {desc}')
        sys.exit(0)
sys.exit(1)
" "$type_name" "$template_name" 2>/dev/null
}

# Prompt user to select optional modules interactively.
# Usage: _prompt_modules <type-name> [template-name]
# Sets SELECTED_MODULES variable (comma-separated) or empty.
_prompt_modules() {
    local type_name="$1"
    local template_name="${2:-}"
    SELECTED_MODULES=""

    local available
    available=$(_list_available_modules "$type_name" "$template_name" 2>/dev/null) || true
    [[ -z "$available" ]] && return 0

    echo ""
    info "Optional modules available:"
    echo "$available"

    # Skip interactive prompt if not a TTY (e.g., called from run.sh)
    if [[ ! -t 0 ]]; then
        return 0
    fi

    echo ""
    read -rp "  Select modules (comma-separated, or enter to skip): " SELECTED_MODULES
}

cmd_init() {
    local name=""
    local project_type=""
    local template=""
    local modules=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)
                name="$2"
                shift 2
                ;;
            --project-type)
                project_type="$2"
                shift 2
                ;;
            --template)
                template="$2"
                shift 2
                ;;
            --modules)
                modules="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            *)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done

    # Check if we're in a git repo
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        echo "Please run this command from within a git repository."
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)

    # Use directory name if no name specified
    if [[ -z "$name" ]]; then
        name=$(basename "$git_root")
    fi

    ensure_config

    # Check if we're in a worktree (not the main repo)
    local current_dir
    current_dir=$(git rev-parse --show-toplevel 2>/dev/null)
    local in_worktree=false
    if [[ "$current_dir" != "$git_root" ]]; then
        in_worktree=true
    fi

    # Check if project name already exists
    local existing_path
    existing_path=$(get_project_path "$name")
    if [[ -n "$existing_path" ]]; then
        if [[ "$existing_path" == "$git_root" ]]; then
            if $in_worktree; then
                info "Project '$name' already registered. Updating set-core deployment..."
                echo "  Main repo: $git_root"
            else
                info "Project '$name' already registered. Updating set-core deployment..."
            fi
            # Skip registration, proceed to deploy
        else
            error "Project name '$name' is already used for: $existing_path"
            echo "Use --name to specify a different name."
            exit 1
        fi
    else
        # Add project to registry
        local timestamp
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        local tmp
        tmp=$(mktemp)
        jq --arg name "$name" --arg path "$git_root" --arg ts "$timestamp" \
            '.projects[$name] = {"path": $path, "addedAt": $ts}' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

        # Set as default if no default exists
        local current_default
        current_default=$(get_default_project)
        if [[ -z "$current_default" || "$current_default" == "null" ]]; then
            json_set "$CONFIG_FILE" ".default" "\"$name\""
            success "Project '$name' registered and set as default"
        else
            success "Project '$name' registered"
        fi
        echo "  Path: $git_root"
    fi

    # Deploy set-core to main repo
    local _deploy_warnings=0
    echo ""
    info "Deploying set-core to $git_root..."
    deploy_set_tools "$git_root" || ((_deploy_warnings++))

    # Resolve project type: CLI flag > saved project-type.yaml
    if [[ -z "$project_type" ]]; then
        local pt_file="$git_root/set/plugins/project-type.yaml"
        if [[ -f "$pt_file" ]]; then
            project_type=$(grep '^type:' "$pt_file" 2>/dev/null | sed 's/^type: *//' || true)
            if [[ -n "$project_type" ]]; then
                info "Using saved project type: $project_type"
            fi
        fi
    fi

    # Save project type and deploy templates if known
    if [[ -n "$project_type" ]]; then
        # Resolve modules: CLI flag > tracked (before overwrite) > interactive prompt
        local deploy_modules="$modules"
        if [[ -z "$deploy_modules" ]]; then
            deploy_modules=$(_read_tracked_modules "$git_root")
        fi
        # Read tracked template too, for re-init without --template
        local deploy_template="$template"
        if [[ -z "$deploy_template" ]]; then
            local pt_file="$git_root/set/plugins/project-type.yaml"
            if [[ -f "$pt_file" ]]; then
                deploy_template=$(grep '^template:' "$pt_file" 2>/dev/null | sed 's/^template: *//' || true)
            fi
        fi
        if ! _save_project_type "$git_root" "$project_type" "$deploy_template" "$deploy_modules"; then
            error "Failed to set project type '$project_type'. Skipping template deploy."
        else
        # If still no modules, prompt interactively
        if [[ -z "$deploy_modules" ]]; then
            _prompt_modules "$project_type" "$deploy_template"
            deploy_modules="$SELECTED_MODULES"
            # Save interactively selected modules back to project-type.yaml
            if [[ -n "$deploy_modules" ]]; then
                _save_template_modules "$git_root" "$deploy_template" "$deploy_modules"
            fi
        fi
        # Deploy templates from the project type
        _deploy_project_templates "$git_root" "$project_type" "$deploy_template" "$deploy_modules" || {
            warn "Template deployment had issues (check output above)"
        }
        fi  # end _save_project_type success
    fi

    # Write .generated-file-patterns AFTER project-type.yaml is saved
    # (profile_loader needs the yaml to load the correct profile)
    # Runs unconditionally — no-op if no project-type.yaml exists
    _write_generated_file_patterns "$git_root"

    # If called from a worktree, also deploy to the worktree's own .claude/ dir
    # and register MCP for the worktree path scope
    if $in_worktree; then
        echo ""
        info "Deploying set-core to worktree $current_dir..."
        deploy_set_tools "$current_dir" || ((_deploy_warnings++))
    fi
    echo ""
    if [[ $_deploy_warnings -gt 0 ]]; then
        warn "set-core deployment complete for '$name' (with warnings — check output above)"
    else
        success "set-core deployment complete for '$name'"
    fi

    # Initialize OpenSpec if available and not already initialized
    if command -v openspec &>/dev/null; then
        if [[ ! -d "$git_root/openspec" ]]; then
            if (cd "$git_root" && openspec init --tools claude 2>&1 | sed 's/^/    /'); then
                success "  Initialized OpenSpec"
            else
                warn "  OpenSpec init failed (non-fatal)"
            fi
        fi
    fi

    # Register with the web manager API (if running) so the lifecycle
    # service picks up the project without a restart.
    local manager_url="${SET_MANAGER_URL:-http://localhost:7400}"
    local api_body
    api_body=$(jq -nc --arg n "$name" --arg p "$git_root" --arg pt "${project_type:-}" \
        '{name: $n, path: $p, project_type: $pt}')
    local reg_resp
    reg_resp=$(curl -sf -X POST "$manager_url/api/projects" \
        -H 'Content-Type: application/json' -d "$api_body" 2>/dev/null) && {
        local reg_status
        reg_status=$(echo "$reg_resp" | jq -r '.status // empty' 2>/dev/null)
        if [[ "$reg_status" == "ok" ]]; then
            success "Registered with manager at $manager_url"
        elif [[ "$reg_status" == "exists" ]]; then
            info "Already registered with manager"
        fi
    } || info "Manager not running — project will be picked up on next manager start"

    # Run health audit if set-audit is available
    if command -v set-audit &>/dev/null; then
        echo ""
        (cd "$git_root" && set-audit scan --condensed 2>/dev/null) || true
    fi
}

cmd_list() {
    ensure_config

    local projects
    projects=$(jq -r '.projects | keys[]' "$CONFIG_FILE" 2>/dev/null)

    if [[ -z "$projects" ]]; then
        info "No projects registered."
        echo "Run 'set-project init' inside a git repository to register it."
        exit 0
    fi

    local default_project
    default_project=$(get_default_project)

    echo "Registered projects:"
    echo ""

    while IFS= read -r name; do
        local path
        path=$(get_project_path "$name")
        if [[ "$name" == "$default_project" ]]; then
            echo -e "  ${GREEN}* $name${NC} -> $path"
        else
            echo "    $name -> $path"
        fi

        # Show worktrees for this project
        list_project_worktrees_brief "$name" "$path"
    done <<< "$projects"

    echo ""
    if [[ -n "$default_project" && "$default_project" != "null" ]]; then
        echo "Default: $default_project"
    fi
}

list_project_worktrees_brief() {
    local project_name="$1"
    local project_path="$2"

    if [[ ! -d "$project_path" ]]; then
        return
    fi

    # Get worktrees from git
    local worktrees
    worktrees=$(git -C "$project_path" worktree list --porcelain 2>/dev/null)

    if [[ -z "$worktrees" ]]; then
        return
    fi

    local current_path=""

    while IFS= read -r line; do
        if [[ "$line" =~ ^worktree\ (.+)$ ]]; then
            current_path="${BASH_REMATCH[1]}"
        elif [[ -z "$line" && -n "$current_path" ]]; then
            # Skip main repo, only show worktrees
            if [[ "$current_path" != "$project_path" ]]; then
                local wt_name
                wt_name=$(basename "$current_path")
                echo -e "      ${BLUE}└─ $wt_name${NC} -> $current_path"
            fi
            current_path=""
        fi
    done <<< "$worktrees"

    # Process last entry
    if [[ -n "$current_path" && "$current_path" != "$project_path" ]]; then
        local wt_name
        wt_name=$(basename "$current_path")
        echo -e "      ${BLUE}└─ $wt_name${NC} -> $current_path"
    fi
}

cmd_remove() {
    local name="$1"

    if [[ -z "$name" ]]; then
        error "Project name required"
        echo "Usage: set-project remove <name>"
        exit 1
    fi

    ensure_config

    local path
    path=$(get_project_path "$name")
    if [[ -z "$path" ]]; then
        error "Project '$name' not found"
        exit 1
    fi

    # Remove from registry
    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" 'del(.projects[$name])' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    # Clear default if this was the default
    local current_default
    current_default=$(get_default_project)
    if [[ "$current_default" == "$name" ]]; then
        json_set "$CONFIG_FILE" ".default" "null"
        warn "Cleared default project (was '$name')"
    fi

    success "Project '$name' removed from registry"
    echo "Note: Existing worktrees were not deleted."
}

cmd_default() {
    local name="$1"

    if [[ -z "$name" ]]; then
        error "Project name required"
        echo "Usage: set-project default <name>"
        exit 1
    fi

    ensure_config

    local path
    path=$(get_project_path "$name")
    if [[ -z "$path" ]]; then
        error "Project '$name' not found"
        echo "Run 'set-project list' to see available projects."
        exit 1
    fi

    json_set "$CONFIG_FILE" ".default" "\"$name\""
    success "Default project set to '$name'"
}

# Migrate legacy files to set/ directory structure.
# Uses git mv when in a git repo, plain mv otherwise.
cmd_migrate() {
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)
    local use_git=true
    local migrated=0

    # Helper: move file/dir with git mv or plain mv
    _migrate_move() {
        local src="$1"
        local dst="$2"
        mkdir -p "$(dirname "$dst")"
        if $use_git; then
            git -C "$git_root" mv "$src" "$dst" 2>/dev/null || mv "$src" "$dst"
        else
            mv "$src" "$dst"
        fi
    }

    # 1. orchestration.yaml → set/orchestration/config.yaml
    local orch_src="$git_root/.claude/orchestration.yaml"
    local orch_dst="$git_root/set/orchestration/config.yaml"
    if [[ -f "$orch_src" && ! -f "$orch_dst" ]]; then
        _migrate_move "$orch_src" "$orch_dst"
        success "  Migrated .claude/orchestration.yaml → set/orchestration/config.yaml"
        migrated=$((migrated + 1))
    fi

    # 2. project-knowledge.yaml → set/knowledge/project-knowledge.yaml
    local pk_src="$git_root/project-knowledge.yaml"
    local pk_dst="$git_root/set/knowledge/project-knowledge.yaml"
    if [[ -f "$pk_src" && ! -f "$pk_dst" ]]; then
        _migrate_move "$pk_src" "$pk_dst"
        success "  Migrated project-knowledge.yaml → set/knowledge/project-knowledge.yaml"
        migrated=$((migrated + 1))
    fi

    # 3. docs/orchestration-runs/* → set/orchestration/runs/
    local runs_src="$git_root/docs/orchestration-runs"
    local runs_dst="$git_root/set/orchestration/runs"
    if [[ -d "$runs_src" ]] && ls "$runs_src"/*.md &>/dev/null; then
        mkdir -p "$runs_dst"
        for f in "$runs_src"/*.md; do
            local fname
            fname=$(basename "$f")
            if [[ ! -f "$runs_dst/$fname" ]]; then
                _migrate_move "$f" "$runs_dst/$fname"
            fi
        done
        # Remove empty source dir
        rmdir "$runs_src" 2>/dev/null || true
        success "  Migrated docs/orchestration-runs/ → set/orchestration/runs/"
        migrated=$((migrated + 1))
    fi

    # 4. docs/v[0-9]*.md (legacy spec files) → set/orchestration/specs/archive/
    local specs_dst="$git_root/set/orchestration/specs/archive"
    local found_specs=false
    for f in "$git_root"/docs/v[0-9]*.md; do
        [[ -f "$f" ]] || continue
        found_specs=true
        local fname
        fname=$(basename "$f")
        if [[ ! -f "$specs_dst/$fname" ]]; then
            _migrate_move "$f" "$specs_dst/$fname"
        fi
    done
    if $found_specs; then
        success "  Migrated docs/v*.md spec files → set/orchestration/specs/archive/"
        migrated=$((migrated + 1))
    fi

    if [[ $migrated -eq 0 ]]; then
        info "No legacy files found to migrate."
    else
        success "Migrated $migrated item(s). Review with 'git status' and commit."
    fi
}

cmd_init_knowledge() {
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)
    # Prefer set/knowledge/ when set/ exists, fallback to project root
    local pk_file="$git_root/project-knowledge.yaml"
    if [[ -d "$git_root/set/knowledge" ]]; then
        pk_file="$git_root/set/knowledge/project-knowledge.yaml"
    fi
    local template="$SET_TOOLS_ROOT/templates/project-knowledge.yaml"

    if [[ -f "$pk_file" ]]; then
        info "project-knowledge.yaml already exists at $pk_file"
        echo "Edit it manually to add cross-cutting files and features."
        return 0
    fi
    # Also check legacy location if targeting wt/
    if [[ "$pk_file" == *"/set/knowledge/"* && -f "$git_root/project-knowledge.yaml" ]]; then
        info "project-knowledge.yaml exists at project root. Run 'set-project migrate' to move it."
        return 0
    fi

    # Check if a project type is configured — use its templates instead of generic
    local pt_yaml="$git_root/set/plugins/project-type.yaml"
    if [[ -f "$pt_yaml" ]]; then
        local pt_name
        pt_name=$(grep '^type:' "$pt_yaml" 2>/dev/null | awk '{print $2}' || true)
        if [[ -n "$pt_name" && "$pt_name" != "base" ]]; then
            info "Project type '$pt_name' configured — deploying type-specific templates"
            _deploy_project_templates "$git_root" "$pt_name" "" || true
            # Cross-cutting checklist deploys via templates/core/rules/ in _deploy_skills
            return 0
        fi
    fi

    # Fallback to generic template
    if [[ ! -f "$template" ]]; then
        error "Template not found: $template"
        exit 1
    fi

    # Scan project for common cross-cutting patterns
    local cross_cutting_entries=""
    local found=0

    # i18n / translation files
    local i18n_files
    i18n_files=$(find "$git_root" -maxdepth 5 \( -path "*/i18n/*.json" -o -path "*/locales/*.json" -o -path "*/lang/*.json" \) -not -path "*/node_modules/*" 2>/dev/null | head -5 || true)
    if [[ -n "$i18n_files" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Translation file"$'\n'
            found=$((found + 1))
        done <<< "$i18n_files"
    fi

    # Sidebar / navigation components
    local sidebar
    sidebar=$(find "$git_root" -maxdepth 5 \( -iname "*sidebar*" -o -iname "*navigation*" -o -iname "*nav-menu*" \) -not -path "*/node_modules/*" 2>/dev/null | grep -E '\.(tsx?|jsx?|vue|svelte)$' || true)
    if [[ -n "$sidebar" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Navigation component"$'\n'
            found=$((found + 1))
        done <<< "$sidebar"
    fi

    # Route definitions
    local routes
    routes=$(find "$git_root" -maxdepth 5 \( -iname "routes.*" -o -iname "router.*" \) -not -path "*/node_modules/*" 2>/dev/null | grep -E '\.(tsx?|jsx?|py|rb)$' || true)
    if [[ -n "$routes" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Route definitions"$'\n'
            found=$((found + 1))
        done <<< "$routes"
    fi

    # Database schema files
    local schemas
    schemas=$(find "$git_root" -maxdepth 4 \( -iname "schema.prisma" -o -iname "schema.rb" \) -not -path "*/node_modules/*" 2>/dev/null | head -3 || true)
    if [[ -n "$schemas" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Database schema"$'\n'
            found=$((found + 1))
        done <<< "$schemas"
    fi

    # Copy template
    cp "$template" "$pk_file"

    # If we found cross-cutting files, inject them
    if [[ -n "$cross_cutting_entries" && "$found" -gt 0 ]]; then
        # Replace the commented examples under cross_cutting_files with actual entries
        local tmp
        tmp=$(mktemp)
        awk -v entries="$cross_cutting_entries" '
            /^cross_cutting_files:/ { print; found=1; next }
            found && /^[^ #]/ { printf "%s", entries; found=0 }
            found && /^  #/ { next }
            { print }
            END { if (found) printf "%s", entries }
        ' "$pk_file" > "$tmp" && mv "$tmp" "$pk_file"
    fi

    success "Created $pk_file"
    if [[ "$found" -gt 0 ]]; then
        info "Auto-detected $found cross-cutting file(s) — review and edit the file"
    else
        info "No cross-cutting files auto-detected — edit manually to add entries"
    fi

    # Cross-cutting checklist deploys via templates/core/rules/ in _deploy_skills
}

# Main
if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

case "$1" in
    init)
        shift
        cmd_init "$@"
        ;;
    init-knowledge)
        shift
        cmd_init_knowledge "$@"
        ;;
    migrate)
        shift
        cmd_migrate "$@"
        ;;
    list|ls)
        cmd_list
        ;;
    list-types)
        echo "Available project types:"
        _list_project_types
        ;;
    remove|rm)
        shift
        cmd_remove "$@"
        ;;
    default)
        shift
        cmd_default "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        error "Unknown command: $1"
        usage
        exit 1
        ;;
esac
