#!/usr/bin/env bash
# set-design-sync — Parse design sources and sync with spec files
#
# Usage:
#   set-design-sync --input docs/design.make --spec-dir docs/
#   set-design-sync --input docs/design.make --spec-dir docs/ --output docs/design-system.md
#   set-design-sync --input docs/design.make --spec-dir docs/ --dry-run
#
# Supported formats:
#   .make  — Figma Make export (ZIP with ai_chat.json)
#   .md    — Existing design-system.md (passthrough)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SET_TOOLS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find Python
_py() {
    if command -v python3 &>/dev/null; then
        echo python3
    elif command -v python &>/dev/null; then
        echo python
    else
        echo "Error: python3 not found" >&2
        exit 1
    fi
}

PY=$(_py)
export PYTHONPATH="$SET_TOOLS_ROOT/lib:${PYTHONPATH:-}"

exec "$PY" -m set_orch.design_parser "$@"
