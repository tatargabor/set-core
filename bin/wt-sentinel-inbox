#!/usr/bin/env python3
"""CLI for sentinel inbox — lightweight message checking.

Usage:
    wt-sentinel-inbox check     # Print new messages, update cursor
    wt-sentinel-inbox ack       # Reset cursor (re-read all)
"""

import json
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "lib"))

from wt_orch.sentinel.inbox import check_inbox, INBOX_CURSOR_FILE
from wt_orch.sentinel.wt_dir import ensure_wt_dir


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Sentinel inbox")
    parser.add_argument("--project", default=os.getcwd(), help="Project path")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("check", help="Check for new messages")
    sub.add_parser("ack", help="Reset cursor to re-read all messages")

    args = parser.parse_args()

    if args.command == "check":
        messages = check_inbox(args.project)
        if not messages:
            # Exit silently — no messages
            sys.exit(0)
        for msg in messages:
            print(f'📨 {msg.get("from", "?")} [{msg.get("timestamp", "")}]: {msg.get("content", "")}')

    elif args.command == "ack":
        sentinel_dir = ensure_wt_dir(args.project)
        cursor_path = os.path.join(sentinel_dir, INBOX_CURSOR_FILE)
        if os.path.exists(cursor_path):
            os.remove(cursor_path)
            print("Cursor reset — next check will read all messages")
        else:
            print("No cursor to reset")


if __name__ == "__main__":
    main()
