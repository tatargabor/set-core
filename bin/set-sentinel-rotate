#!/usr/bin/env python3
"""CLI for sentinel run rotation — archive old events and findings."""

import json
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "lib"))

from set_orch.sentinel.rotation import rotate


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Rotate sentinel events and findings for a new run")
    parser.add_argument("--project", default=os.getcwd(), help="Project path")
    args = parser.parse_args()

    result = rotate(args.project)
    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
