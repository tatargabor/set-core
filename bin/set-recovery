#!/usr/bin/env bash
# set-recovery — Roll back orchestration to a known-good state
# Usage: set-recovery <project-name> <target-change> [--dry-run] [--yes]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SET_TOOLS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export PYTHONPATH="$SET_TOOLS_ROOT/lib:${PYTHONPATH:-}"

exec python3 -m set_orch.recovery_cli "$@"
