#!/usr/bin/env bash
# set-figma-fetch - Fetch Figma design data via direct MCP calls

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/set-common.sh"

usage() {
    cat <<EOF
Usage: set-figma-fetch <docs-dir> [options]
       set-figma-fetch <figma-url> -o <output-dir>

Fetch Figma design data via direct MCP protocol calls (no Claude subprocess).
Saves raw MCP responses + assembled design-snapshot.md.

Modes:
  <docs-dir>              Scan docs-dir/**/*.md for Figma URLs, fetch all
  <figma-url> -o <dir>    Fetch a single Figma file into dir

Options:
  --force                 Re-fetch even if snapshots exist
  --reprocess             Re-assemble from existing raw files (no MCP calls)
  -o, --output <dir>      Output directory (single URL mode only)
  -h, --help              Show this help

Examples:
  set-figma-fetch docs/
  set-figma-fetch --force docs/
  set-figma-fetch --reprocess docs/
  set-figma-fetch https://figma.com/make/ABC123 -o docs/figma-raw/ABC123/

Prerequisites:
  - Figma MCP authenticated in Claude Code (OAuth token in ~/.claude/.credentials.json)
  - Python mcp SDK installed
EOF
}

# ─── Args ─────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage
    exit 0
fi

# Find Python with mcp SDK
PYTHON=""
for candidate in python3 "$HOME/miniconda3/bin/python3"; do
    if command -v "$candidate" &>/dev/null; then
        if "$candidate" -c "import mcp" 2>/dev/null; then
            PYTHON="$candidate"
            break
        fi
    fi
done

if [[ -z "$PYTHON" ]]; then
    error "Python with mcp SDK not found. Install: pip install mcp"
    exit 1
fi

# Locate fetcher.py
FETCHER="$SCRIPT_DIR/../lib/design/fetcher.py"
if [[ ! -f "$FETCHER" ]]; then
    error "fetcher.py not found at $FETCHER"
    exit 1
fi

# Forward all args to Python
info "Using Python: $PYTHON"
exec "$PYTHON" "$FETCHER" "$@"
