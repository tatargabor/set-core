#!/usr/bin/env bash
# wt-sentinel — Supervised wrapper for wt-orchestrate start.
# Restarts the orchestrator on crash with backoff. Stops on clean exit or user interrupt.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<EOF
Usage: wt-sentinel [wt-orchestrate start options...]

Runs 'wt-orchestrate start' in a supervised loop. If the orchestrator
crashes (non-zero exit), it restarts after a 30s backoff. Stops on:
  - Clean exit with state "done" (orchestration complete)
  - Clean exit with state "stopped" (user Ctrl+C)
  - 5 rapid consecutive crashes (each <5 min runtime)
  - SIGINT/SIGTERM (forwarded to child, no restart)

All arguments are passed through to 'wt-orchestrate start'.

Examples:
  wt-sentinel
  wt-sentinel --spec docs/v5.md --max-parallel 3
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

STATE_FILE="orchestration-state.json"
LOG_FILE="orchestration.log"
PID_FILE="sentinel.pid"
MAX_RAPID_CRASHES=5
SUSTAINED_RUN_SECS=300  # 5 minutes
BACKOFF_SECS=30

sentinel_log() {
    local msg="[$(date '+%Y-%m-%dT%H:%M:%S%z')] [sentinel] $*"
    echo "$msg"
    echo "$msg" >> "$LOG_FILE"
}

# Signal handling — don't restart after user interrupt
interrupted=false
child_pid=0

cleanup() {
    rm -f "$PID_FILE"
}

handle_signal() {
    interrupted=true
    if [[ $child_pid -gt 0 ]]; then
        kill -TERM "$child_pid" 2>/dev/null || true
    fi
}

trap cleanup EXIT
trap handle_signal SIGINT SIGTERM SIGHUP

# Write PID file
echo $$ > "$PID_FILE"

rapid_crashes=0

while true; do
    # Fix stale state before restart
    if [[ -f "$STATE_FILE" ]]; then
        current_status=$(jq -r '.status // ""' "$STATE_FILE" 2>/dev/null || true)
        if [[ "$current_status" == "running" ]]; then
            # No orchestrator process but state says running — reset to stopped
            sentinel_log "Stale state detected (status=running but no process) — resetting to stopped"
            jq '.status = "stopped"' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        elif [[ "$current_status" == "checkpoint" ]]; then
            # Checkpoint persists across restarts — don't modify
            sentinel_log "State is checkpoint — preserving (orchestrator will resume from checkpoint)"
        fi
    fi

    # Launch orchestrator
    start_epoch=$(date +%s)
    child_pid=0
    "$SCRIPT_DIR/wt-orchestrate" start "$@" &
    child_pid=$!
    wait $child_pid || true
    exit_code=$?
    child_pid=0
    end_epoch=$(date +%s)
    runtime=$((end_epoch - start_epoch))

    # Don't restart if we received a signal
    if $interrupted; then
        sentinel_log "Interrupted — exiting"
        exit 0
    fi

    # Check state to decide whether to restart
    final_status=""
    if [[ -f "$STATE_FILE" ]]; then
        final_status=$(jq -r '.status // ""' "$STATE_FILE" 2>/dev/null || true)
    fi

    # Clean exit + done = orchestration complete
    if [[ $exit_code -eq 0 && "$final_status" == "done" ]]; then
        sentinel_log "Orchestration complete (status=done)"
        exit 0
    fi

    # Clean exit + stopped = user stopped it (Ctrl+C reached orchestrator)
    if [[ $exit_code -eq 0 && "$final_status" == "stopped" ]]; then
        sentinel_log "Orchestrator stopped cleanly"
        exit 0
    fi

    # Clean exit + time_limit = user set a limit, respect it
    if [[ $exit_code -eq 0 && "$final_status" == "time_limit" ]]; then
        sentinel_log "Time limit reached — stopping (run 'wt-orchestrate start' to resume)"
        exit 0
    fi

    # Any other clean exit = unexpected state, default to stop (safe)
    if [[ $exit_code -eq 0 ]]; then
        sentinel_log "Orchestrator exited cleanly with unexpected state '$final_status' — stopping"
        exit 0
    fi

    # Non-zero exit = crash — track rapid crashes
    if [[ $runtime -ge $SUSTAINED_RUN_SECS ]]; then
        rapid_crashes=0  # Ran long enough — reset counter
    else
        rapid_crashes=$((rapid_crashes + 1))
    fi

    if [[ $rapid_crashes -ge $MAX_RAPID_CRASHES ]]; then
        sentinel_log "ERROR: $MAX_RAPID_CRASHES rapid crashes — giving up"
        exit 1
    fi

    sentinel_log "Orchestrator exited (code=$exit_code, runtime=${runtime}s, rapid_crashes=$rapid_crashes/$MAX_RAPID_CRASHES)"
    sentinel_log "Restarting in ${BACKOFF_SECS}s..."
    sleep $BACKOFF_SECS
done
