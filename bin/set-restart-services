#!/usr/bin/env bash
# Restart set-core unified service.
# Usage: set-restart-services
set -euo pipefail

SET_CORE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

restart_unified() {
    echo "Restarting set-core unified service (port 7400)..."

    # Kill any existing service on port 7400
    local port_pid
    port_pid=$(lsof -ti:7400 2>/dev/null || true)
    if [[ -n "$port_pid" ]]; then
        kill "$port_pid" 2>/dev/null || true
        sleep 1
    fi

    # Also kill legacy manager on 3112 if running
    local mgr_pid
    mgr_pid=$(lsof -ti:3112 2>/dev/null || true)
    if [[ -n "$mgr_pid" ]]; then
        kill "$mgr_pid" 2>/dev/null || true
        sleep 1
    fi

    cd "$SET_CORE_ROOT" && pip install -e . -q 2>/dev/null
    nohup set-orch-core serve --port 7400 > /tmp/set-orch-core.log 2>&1 &
    sleep 2
    if curl -sf http://localhost:7400/ > /dev/null 2>&1; then
        echo "  Unified service running on :7400"
    else
        echo "  WARNING: Service may not have started. Check /tmp/set-orch-core.log"
    fi
}

restart_unified
